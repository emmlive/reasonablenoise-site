---
import "../styles/global.css";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Privacy Policy | ReasonableNoise</title>
    <meta name="description" content="Read the ReasonableNoise privacy policy for sticker orders, artwork uploads, payment processing, and customer information." />
    <link rel="icon" type="image/png" href="/assets/rn-logo.png" />
    <link rel="shortcut icon" type="image/png" href="/assets/rn-logo.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
  
    <!-- RN-2I-A SEO START -->
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://reasonablenoise.com/privacy/" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="ReasonableNoise" />
    <meta property="og:title" content="Privacy Policy | ReasonableNoise" />
    <meta property="og:description" content="Read the ReasonableNoise privacy policy for sticker orders, artwork uploads, payment processing, and customer information." />
    <meta property="og:url" content="https://reasonablenoise.com/privacy/" />
    <meta property="og:image" content="https://reasonablenoise.com/assets/rn-logo.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Privacy Policy | ReasonableNoise" />
    <meta name="twitter:description" content="Read the ReasonableNoise privacy policy for sticker orders, artwork uploads, payment processing, and customer information." />
    <meta name="twitter:image" content="https://reasonablenoise.com/assets/rn-logo.png" />
    <!-- RN-2I-A SEO END -->
  </head>

  <body class="min-h-screen bg-[#050608] text-white antialiased">
    <main class="mx-auto max-w-4xl px-6 py-16">
      <a href="/" class="inline-flex items-center gap-3 text-sm text-white/60 hover:text-white">
        <span class="flex h-9 w-9 items-center justify-center rounded-2xl bg-white text-xs font-black text-black">RN</span>
        Back to ReasonableNoise
      </a>

      <section class="py-16">
        <p class="text-sm font-semibold uppercase tracking-[0.3em] text-cyan-300">Privacy Policy</p>
        <h1 class="mt-5 text-5xl font-semibold tracking-[-0.05em]">Privacy Policy</h1>
        <p class="mt-5 text-white/50">Last updated: June 2026</p>

        <div class="mt-10 space-y-8 leading-8 text-white/65">
          <p>
            ReasonableNoise collects the information needed to respond to quote requests, process sticker orders, prepare customer artwork, and communicate about orders.
          </p>

          <section>
            <h2 class="text-2xl font-semibold text-white">Information we collect</h2>
            <p class="mt-3">
              We may collect your name, business name, email address, phone number, order details, USDOT number, design files, uploaded artwork, shipping details, and payment-related information.
            </p>
          </section>

          <section>
            <h2 class="text-2xl font-semibold text-white">How we use information</h2>
            <p class="mt-3">
              We use customer information to prepare quotes, process orders, communicate about designs, complete payments, print stickers, and fulfill customer requests.
            </p>
          </section>

          <section>
            <h2 class="text-2xl font-semibold text-white">Payments</h2>
            <p class="mt-3">
              Online payments may be processed through third-party payment providers such as Stripe or PayPal. ReasonableNoise does not store full card numbers on this website.
            </p>
          </section>

          <section>
            <h2 class="text-2xl font-semibold text-white">Uploaded files</h2>
            <p class="mt-3">
              Uploaded designs and artwork are used to review, prepare, and print customer orders. Customers should only upload files they own or have permission to use.
            </p>
          </section>

          <section>
            <h2 class="text-2xl font-semibold text-white">Contact</h2>
            <p class="mt-3">
              For privacy questions, contact ReasonableNoise through the order or contact form on this website.
            </p>
          </section>
        </div>
      </section>
    </main>
  </body>
</html>




