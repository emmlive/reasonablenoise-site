---
import "../styles/global.css";
import WhatsAppChat from "../components/WhatsAppChat.astro";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Contact ReasonableNoise | Sticker Orders & Custom Decals</title>
    <meta name="description" content="Contact ReasonableNoise for USDOT stickers, custom decals, vehicle lettering, artwork help, pickup, shipping, and order questions." />
    <link rel="icon" type="image/png" href="/assets/rn-logo.png" />
    <link rel="shortcut icon" type="image/png" href="/assets/rn-logo.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://reasonablenoise.com/contact/" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="ReasonableNoise" />
    <meta property="og:title" content="Contact ReasonableNoise | Sticker Orders & Custom Decals" />
    <meta property="og:description" content="Contact ReasonableNoise for USDOT stickers, custom decals, vehicle lettering, artwork help, pickup, shipping, and order questions." />
    <meta property="og:url" content="https://reasonablenoise.com/contact/" />
    <meta property="og:image" content="https://reasonablenoise.com/assets/rn-logo.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Contact ReasonableNoise | Sticker Orders & Custom Decals" />
    <meta name="twitter:description" content="Contact ReasonableNoise for USDOT stickers, custom decals, vehicle lettering, artwork help, pickup, shipping, and order questions." />
    <meta name="twitter:image" content="https://reasonablenoise.com/assets/rn-logo.png" />
  </head>

  <body class="min-h-screen bg-[#050608] text-white antialiased">
    <main class="relative overflow-hidden">
      <div class="absolute inset-0 -z-10">
        <div class="absolute left-1/2 top-0 h-[520px] w-[900px] -translate-x-1/2 rounded-full bg-cyan-500/15 blur-[120px]"></div>
      </div>

      <header class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-4 py-5 sm:px-6">
        <a href="/" class="flex items-center gap-3">
          <div class="flex h-16 w-16 items-center justify-center rounded-3xl bg-black p-2 shadow-lg shadow-black/30 ring-1 ring-white/10">
            <img src="/assets/rn-logo.png" alt="ReasonableNoise logo" class="h-full w-full object-contain" />
          </div>
          <div>
            <p class="text-sm font-semibold tracking-wide">ReasonableNoise</p>
            <p class="text-xs text-white/50">Premium sticker printing</p>
          </div>
        </a>

        <nav class="hidden items-center gap-8 text-sm text-white/70 md:flex">
          <a class="hover:text-white" href="/">Home</a>
          <a class="hover:text-white" href="/usdot-stickers">USDOT Stickers</a>
          <a class="hover:text-white" href="/upload-design">Upload Design</a>
          <a class="text-white" href="/contact">Contact</a>
        </nav>

        <a href="/upload-design" class="rounded-full bg-white px-5 py-2.5 text-sm font-semibold text-black">
          Start Order
        </a>
      </header>

      <section class="mx-auto grid max-w-7xl gap-8 px-4 py-16 sm:px-6 md:grid-cols-[0.9fr_1.1fr] md:py-24">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.3em] text-cyan-300">Contact</p>
          <h1 class="mt-5 text-5xl font-semibold tracking-[-0.05em] md:text-7xl">
            Need help with a sticker order?
          </h1>
          <p class="mt-6 max-w-2xl text-lg leading-8 text-white/60">
            Send a message about USDOT stickers, custom decals, vehicle lettering, artwork upload, pickup, shipping, or DTF T-shirt quote requests.
          </p>

          <div class="mt-10 grid gap-4">
            <a href="mailto:info@reasonablenoise.com" class="rounded-3xl border border-white/10 bg-white/[0.06] p-5 backdrop-blur transition hover:bg-white/[0.09]">
              <p class="font-semibold text-white">Email ReasonableNoise</p>
              <p class="mt-2 text-sm leading-6 text-white/55">info@reasonablenoise.com</p>
            </a>

            <a href="/upload-design" class="rounded-3xl border border-white/10 bg-white/[0.06] p-5 backdrop-blur transition hover:bg-white/[0.09]">
              <p class="font-semibold text-white">Ready to order?</p>
              <p class="mt-2 text-sm leading-6 text-white/55">Start a secure sticker order and upload artwork.</p>
            </a>

            <div class="rounded-3xl border border-white/10 bg-white/[0.06] p-5 backdrop-blur">
              <p class="font-semibold text-white">Fast response tip</p>
              <p class="mt-2 text-sm leading-6 text-white/55">Include sticker type, size, quantity, color, and whether you want pickup or shipping.</p>
            </div>
          </div>
        </div>

        <form id="contact-form" class="rounded-[2.5rem] border border-white/10 bg-white p-5 text-black shadow-2xl shadow-black/40 sm:p-8">
          <div class="mb-8">
            <p class="text-sm font-bold uppercase tracking-[0.3em] text-black/40">Message</p>
            <h2 class="mt-3 text-3xl font-semibold tracking-[-0.04em]">Send a contact request.</h2>
            <p class="mt-3 text-sm leading-6 text-black/55">
              We’ll receive your message by email and follow up as soon as possible.
            </p>
            <p id="contact-message" class="mt-4 hidden rounded-2xl border border-black/10 bg-black/[0.04] px-4 py-3 text-sm font-semibold"></p>
          </div>

          <div class="grid gap-4 md:grid-cols-2">
            <label class="grid gap-2">
              <span class="text-sm font-semibold text-black/70">Name *</span>
              <input name="name" required class="rounded-2xl border border-black/10 bg-black/[0.03] px-4 py-3 outline-none focus:border-black/30" placeholder="Full name" />
            </label>

            <label class="grid gap-2">
              <span class="text-sm font-semibold text-black/70">Email *</span>
              <input name="email" required type="email" class="rounded-2xl border border-black/10 bg-black/[0.03] px-4 py-3 outline-none focus:border-black/30" placeholder="you@email.com" />
            </label>

            <label class="grid gap-2">
              <span class="text-sm font-semibold text-black/70">Phone</span>
              <input name="phone" class="rounded-2xl border border-black/10 bg-black/[0.03] px-4 py-3 outline-none focus:border-black/30" placeholder="Phone number" />
            </label>

            <label class="grid gap-2">
              <span class="text-sm font-semibold text-black/70">Topic</span>
              <select name="contactType" class="rounded-2xl border border-black/10 bg-black/[0.03] px-4 py-3 outline-none focus:border-black/30">
                <option>Sticker order question</option>
                <option>USDOT sticker quote</option>
                <option>Custom decal quote</option>
                <option>Artwork / design help</option>
                <option>Pickup or shipping question</option>
                <option>DTF T-shirt coming soon quote</option>
                <option>Other</option>
              </select>
            </label>

            <label class="grid gap-2 md:col-span-2">
              <span class="text-sm font-semibold text-black/70">Message *</span>
              <textarea name="message" required class="min-h-40 rounded-2xl border border-black/10 bg-black/[0.03] px-4 py-3 outline-none focus:border-black/30" placeholder="Tell us what you need."></textarea>
            </label>
          </div>

          <button id="contact-button" type="submit" class="mt-6 w-full rounded-full bg-black px-6 py-4 text-sm font-bold text-white shadow-xl shadow-black/20 transition hover:bg-black/90">
            Send Message
          </button>

          <p class="mt-4 text-center text-xs leading-5 text-black/45">
            You can also email info@reasonablenoise.com directly.
          </p>
        </form>
      </section>

      <footer class="mx-auto flex max-w-7xl flex-col gap-4 px-4 py-10 text-sm text-white/45 sm:px-6 md:flex-row md:items-center md:justify-between">
        <p>© 2026 ReasonableNoise. Premium sticker printing.</p>
        <div class="flex flex-wrap gap-5">
          <a href="/" class="hover:text-white">Home</a>
          <a href="/usdot-stickers" class="hover:text-white">USDOT Stickers</a>
          <a href="/upload-design" class="hover:text-white">Upload Design</a>
          <a href="/privacy" class="hover:text-white">Privacy</a>
          <a href="/terms" class="hover:text-white">Terms</a>
        </div>
      </footer>
    </main>

    <script>
      const form = document.getElementById("contact-form");
      const button = document.getElementById("contact-button");
      const message = document.getElementById("contact-message");

      function showContactMessage(text, isError = false) {
        if (!message) return;
        message.textContent = text;
        message.classList.remove("hidden");
        message.classList.toggle("text-red-600", isError);
        message.classList.toggle("text-emerald-700", !isError);
      }

      function applyContactPrefill() {
        const params = new URLSearchParams(window.location.search);
        const topic = params.get("topic");

        if (topic !== "dtf" || !form) return;

        const contactType = form.elements.contactType;
        const messageField = form.elements.message;

        if (contactType) {
          contactType.value = "DTF T-shirt coming soon quote";
        }

        if (messageField && !messageField.value) {
          messageField.placeholder = "Tell us about your DTF shirt request: quantity, shirt color, print size, front/back print, artwork status, and deadline.";
        }

        showContactMessage("DTF quote request selected. Send your shirt details and we’ll follow up.", false);
      }

      applyContactPrefill();

      form?.addEventListener("submit", async (event) => {
        event.preventDefault();

        button.disabled = true;
        button.textContent = "Sending message...";
        showContactMessage("Sending your message...");

        const payload = Object.fromEntries(new FormData(form).entries());

        try {
          const response = await fetch("/api/contact", {
            method: "POST",
            headers: { "content-type": "application/json" },
            body: JSON.stringify(payload),
          });

          const data = await response.json();

          if (!response.ok || !data.success) {
            throw new Error(data.error || "Unable to send message.");
          }

          form.reset();
          showContactMessage("Message sent. We’ll follow up soon.");
          button.textContent = "Message Sent";
        } catch (error) {
          showContactMessage(error.message || "Unable to send message.", true);
          button.disabled = false;
          button.textContent = "Send Message";
        }
      });
    </script>

    <WhatsAppChat />
  </body>
</html>
