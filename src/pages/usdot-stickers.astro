---
import "../styles/global.css";

const usdotSeoFaqs = [
  {
    question: "What information do I need for USDOT stickers?",
    answer:
      "You usually need the company or legal business name, USDOT number, preferred size, color, quantity, and whether the decals are for a truck, trailer, van, or fleet vehicle.",
  },
  {
    question: "Can ReasonableNoise make custom truck lettering?",
    answer:
      "Yes. ReasonableNoise can prepare USDOT number decals, commercial truck lettering, business vehicle decals, and matching fleet lettering for multiple vehicles.",
  },
  {
    question: "Can I upload my logo or artwork?",
    answer:
      "Yes. You can upload your logo, artwork, reference image, or design file through the secure order form before checkout.",
  },
  {
    question: "Do you offer local pickup or shipping?",
    answer:
      "Yes. You can choose local pickup with no shipping fee or select shipping during checkout. Stripe collects the shipping address when shipping is selected.",
  },
];

const usdotPricingItems = [
  {
    name: "USDOT sticker pair",
    price: "$29",
    note: "Launch price for one standard pair. Normally $30.",
  },
  {
    name: "Extra matching pair",
    price: "$25",
    note: "Add a backup pair or another vehicle pair in the same order.",
  },
  {
    name: "One-side replacement",
    price: "$18",
    note: "For one truck door or one replacement decal.",
  },
  {
    name: "USDOT + business name pair",
    price: "$39",
    note: "Includes USDOT number with company or legal business name.",
  },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>USDOT Stickers &amp; Commercial Vehicle Decals | ReasonableNoise</title>
    <meta name="description" content="Order clean, sharp USDOT stickers, commercial truck decals, trailer lettering, and fleet marking decals from ReasonableNoise." />
    <link rel="icon" type="image/png" href="/assets/rn-logo.png" />
    <link rel="shortcut icon" type="image/png" href="/assets/rn-logo.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
  
    <!-- RN-2I-A SEO START -->
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://reasonablenoise.com/usdot-stickers/" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="ReasonableNoise" />
    <meta property="og:title" content="USDOT Stickers &amp; Commercial Vehicle Decals | ReasonableNoise" />
    <meta property="og:description" content="Order clean, sharp USDOT stickers, commercial truck decals, trailer lettering, and fleet marking decals from ReasonableNoise." />
    <meta property="og:url" content="https://reasonablenoise.com/usdot-stickers/" />
    <meta property="og:image" content="https://reasonablenoise.com/assets/rn-logo.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="USDOT Stickers &amp; Commercial Vehicle Decals | ReasonableNoise" />
    <meta name="twitter:description" content="Order clean, sharp USDOT stickers, commercial truck decals, trailer lettering, and fleet marking decals from ReasonableNoise." />
    <meta name="twitter:image" content="https://reasonablenoise.com/assets/rn-logo.png" />
    <script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "USDOT Stickers and Commercial Vehicle Decals",
  "provider": {
    "@type": "Organization",
    "name": "ReasonableNoise",
    "url": "https://reasonablenoise.com"
  },
  "areaServed": "United States",
  "serviceType": "Custom sticker printing and vehicle decals"
}
    </script>
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      mainEntity: usdotSeoFaqs.map((item) => ({
        "@type": "Question",
        name: item.question,
        acceptedAnswer: {
          "@type": "Answer",
          text: item.answer,
        },
      })),
    })} />
    <!-- RN-2I-A SEO END -->
  </head>

  <body class="min-h-screen bg-[#050608] text-white antialiased">
    <main class="relative overflow-hidden">
      <div class="absolute inset-0 -z-10">
        <div class="absolute left-1/2 top-0 h-[520px] w-[900px] -translate-x-1/2 rounded-full bg-cyan-500/15 blur-[120px]"></div>
        <div class="absolute right-[-120px] top-[300px] h-[420px] w-[420px] rounded-full bg-blue-500/10 blur-[100px]"></div>
      </div>

      <header class="mx-auto flex max-w-7xl items-center justify-between px-6 py-6">
        <a href="/" class="flex items-center gap-3">
          <div class="flex h-16 w-16 items-center justify-center rounded-3xl bg-black p-2 shadow-lg shadow-black/30 ring-1 ring-white/10">
            <img
              src="/assets/rn-logo.png"
              alt="ReasonableNoise logo"
              class="h-full w-full object-contain"
            />
          </div>
          <div>
            <p class="text-sm font-semibold tracking-wide">ReasonableNoise</p>
            <p class="text-xs text-white/50">Premium sticker printing</p>
          </div>
        </a>

        <nav class="hidden items-center gap-8 text-sm text-white/70 md:flex">
          <a class="hover:text-white" href="/">Home</a>
          <a class="text-white" href="/usdot-stickers">USDOT Stickers</a>
          <a class="hover:text-white" href="/upload-design">Upload Design</a>
        </nav>

        <a
          href="/upload-design"
          class="rounded-full border border-white/15 bg-white px-5 py-2.5 text-sm font-semibold text-black shadow-2xl shadow-white/10 transition hover:bg-white/90"
        >
          Start Order
        </a>
      </header>

      <section class="mx-auto max-w-7xl px-6 pb-20 pt-16 md:pb-28 md:pt-24">
        <div class="max-w-4xl">
          <div class="mb-6 inline-flex rounded-full border border-white/10 bg-white/5 px-4 py-2 text-sm text-white/70 backdrop-blur">
            USDOT numbers • commercial truck decals • fleet lettering
          </div>

          <h1 class="text-5xl font-semibold tracking-[-0.05em] md:text-7xl">
            USDOT Stickers made clean, sharp, and easy to order.
          </h1>

          <p class="mt-7 max-w-2xl text-lg leading-8 text-white/65">
            Get professional USDOT number decals for trucks, trailers, vans, and commercial vehicles. Send your company name and USDOT number, choose your size and color, and we prepare your sticker set for print.
          </p>

          <div class="mt-9 flex flex-col gap-4 sm:flex-row">
            <a
              href="/upload-design"
              class="rounded-full bg-white px-7 py-4 text-center text-sm font-bold text-black shadow-2xl shadow-white/10 transition hover:bg-white/90"
            >
              Order USDOT Stickers
            </a>
            <a
              href="#packages"
              class="rounded-full border border-white/15 bg-white/5 px-7 py-4 text-center text-sm font-bold text-white backdrop-blur transition hover:bg-white/10"
            >
              View Packages
            </a>
          </div>
        </div>
      </section>

      <section id="packages" class="mx-auto max-w-7xl px-6 py-20">
        <div class="mb-10">
          <p class="text-sm font-semibold uppercase tracking-[0.3em] text-cyan-300">USDOT Packages</p>
          <h2 class="mt-4 max-w-3xl text-4xl font-semibold tracking-[-0.04em] md:text-5xl">
            Built for commercial vehicles and business fleets.
          </h2>
        </div>

        <div class="grid gap-5 md:grid-cols-3">
          <article class="rounded-[2rem] border border-white/10 bg-white/[0.06] p-7 backdrop-blur">
            <p class="text-sm font-semibold uppercase tracking-[0.25em] text-cyan-300">Starter</p>
            <h3 class="mt-5 text-2xl font-semibold">USDOT Sticker Set</h3>
            <p class="mt-4 leading-7 text-white/60">
              Left and right side USDOT decals with your company name and USDOT number.
            </p>
            <p class="mt-8 text-sm text-white/50">Best for single truck or trailer orders.</p>
          </article>

          <article class="rounded-[2rem] border border-cyan-300/30 bg-cyan-300/[0.08] p-7 backdrop-blur">
            <p class="text-sm font-semibold uppercase tracking-[0.25em] text-cyan-300">Popular</p>
            <h3 class="mt-5 text-2xl font-semibold">Truck + Trailer Set</h3>
            <p class="mt-4 leading-7 text-white/60">
              USDOT decals plus matching business lettering for a cleaner commercial look.
            </p>
            <p class="mt-8 text-sm text-white/50">Best for owner-operators and small fleets.</p>
          </article>

          <article class="rounded-[2rem] border border-white/10 bg-white/[0.06] p-7 backdrop-blur">
            <p class="text-sm font-semibold uppercase tracking-[0.25em] text-cyan-300">Fleet</p>
            <h3 class="mt-5 text-2xl font-semibold">Multi-Vehicle Package</h3>
            <p class="mt-4 leading-7 text-white/60">
              Consistent USDOT decals and branding for multiple trucks, vans, or trailers.
            </p>
            <p class="mt-8 text-sm text-white/50">Best for businesses with several vehicles.</p>
          </article>
        </div>
      </section>


      <section class="mx-auto max-w-7xl px-4 py-14 sm:px-6 md:py-20">
        <div class="rounded-[2.5rem] border border-white/10 bg-white/[0.06] p-5 backdrop-blur sm:p-8 md:p-12">
          <div class="mb-8">
            <p class="text-sm font-semibold uppercase tracking-[0.3em] text-cyan-300">USDOT Pricing</p>
            <h2 class="mt-4 max-w-3xl text-4xl font-semibold tracking-[-0.04em] md:text-5xl">
              USDOT pricing that is clear before checkout.
            </h2>
            <p class="mt-4 max-w-3xl leading-7 text-white/60">
              Start with simple USDOT sticker pricing, then add details like business name, quantity, size, color, and vehicle type. Final pricing is confirmed after order review.
            </p>
          </div>

          <div class="grid gap-4 md:grid-cols-4">
            {usdotPricingItems.map((item) => (
              <article class="rounded-3xl border border-white/10 bg-black/20 p-5">
                <p class="text-sm font-semibold text-white/55">{item.name}</p>
                <p class="mt-3 text-3xl font-bold tracking-[-0.04em] text-white">{item.price}</p>
                <p class="mt-3 text-sm leading-6 text-white/55">{item.note}</p>
              </article>
            ))}
          </div>

          <div class="mt-7 flex flex-col gap-3 sm:flex-row">
            <a href="/upload-design" class="rounded-full bg-white px-6 py-3 text-center text-sm font-bold text-black">
              Start USDOT Order
            </a>
            <a href="/faq" class="rounded-full border border-white/15 px-6 py-3 text-center text-sm font-bold text-white">
              Read FAQ
            </a>
          </div>
        </div>
      </section>

      <section class="mx-auto max-w-7xl px-4 py-14 sm:px-6 md:py-20">
        <div class="grid gap-8 rounded-[2.5rem] border border-white/10 bg-white/[0.06] p-5 backdrop-blur sm:p-8 md:grid-cols-[0.9fr_1.1fr] md:p-12">
          <div>
            <p class="text-sm font-semibold uppercase tracking-[0.3em] text-cyan-300">Commercial Vehicle Decals</p>
            <h2 class="mt-4 text-4xl font-semibold tracking-[-0.04em] md:text-5xl">
              Commercial vehicle decals built for USDOT numbers, truck lettering, and fleet branding.
            </h2>
            <p class="mt-5 leading-7 text-white/60">
              ReasonableNoise makes it easier to order clean USDOT stickers and custom vehicle decals for commercial trucks, trailers, vans, and service fleets. Whether you need a simple USDOT number sticker set or matching business lettering across multiple vehicles, the order flow is built to collect the details, artwork, and fulfillment preference in one place.
            </p>
          </div>

          <div class="grid gap-4 sm:grid-cols-2">
            <div class="rounded-3xl border border-white/10 bg-black/20 p-5">
              <p class="font-bold text-white">USDOT number decals</p>
              <p class="mt-2 text-sm leading-6 text-white/55">
                Clear USDOT lettering for trucks, trailers, vans, and commercial vehicle doors.
              </p>
            </div>

            <div class="rounded-3xl border border-white/10 bg-black/20 p-5">
              <p class="font-bold text-white">Commercial truck lettering</p>
              <p class="mt-2 text-sm leading-6 text-white/55">
                Add your business name, legal name, phone number, or brand details to your vehicle.
              </p>
            </div>

            <div class="rounded-3xl border border-white/10 bg-black/20 p-5">
              <p class="font-bold text-white">Fleet decal consistency</p>
              <p class="mt-2 text-sm leading-6 text-white/55">
                Keep the same clean style across multiple trucks, vans, trailers, or service vehicles.
              </p>
            </div>

            <div class="rounded-3xl border border-white/10 bg-black/20 p-5">
              <p class="font-bold text-white">Secure artwork upload</p>
              <p class="mt-2 text-sm leading-6 text-white/55">
                Upload logos, reference files, or design artwork before checkout so production can start faster.
              </p>
            </div>
          </div>
        </div>
      </section>

      <section class="mx-auto max-w-7xl px-4 py-14 sm:px-6 md:py-20">
        <div class="grid gap-8 rounded-[2rem] border border-white/10 bg-white p-5 text-black sm:p-8 md:grid-cols-2 md:rounded-[2.5rem] md:p-12">
          <div>
            <p class="text-sm font-bold uppercase tracking-[0.3em] text-black/50">What we need</p>
            <h2 class="mt-4 text-4xl font-semibold tracking-[-0.04em] md:text-5xl">
              Send the details. We prepare the layout.
            </h2>
          </div>

          <div class="grid gap-4">
            <div class="rounded-3xl border border-black/10 bg-black/[0.03] p-5">
              <p class="font-bold">Company or legal business name</p>
              <p class="mt-2 text-sm leading-6 text-black/60">The name you want displayed on the vehicle decal.</p>
            </div>
            <div class="rounded-3xl border border-black/10 bg-black/[0.03] p-5">
              <p class="font-bold">USDOT number</p>
              <p class="mt-2 text-sm leading-6 text-black/60">The number that should appear after “USDOT”.</p>
            </div>
            <div class="rounded-3xl border border-black/10 bg-black/[0.03] p-5">
              <p class="font-bold">Color, size, and quantity</p>
              <p class="mt-2 text-sm leading-6 text-black/60">Choose a clean style that fits your truck, trailer, or fleet.</p>
            </div>
          </div>
        </div>
      </section>


      <section class="mx-auto max-w-7xl px-4 py-14 sm:px-6 md:py-20">
        <div class="mb-10">
          <p class="text-sm font-semibold uppercase tracking-[0.3em] text-cyan-300">FAQ</p>
          <h2 class="mt-4 max-w-3xl text-4xl font-semibold tracking-[-0.04em] md:text-5xl">
            Common USDOT sticker questions.
          </h2>
        </div>

        <div class="grid gap-4 md:grid-cols-2">
          {usdotSeoFaqs.map((item) => (
            <article class="rounded-[2rem] border border-white/10 bg-white/[0.06] p-6 backdrop-blur">
              <h3 class="text-xl font-semibold text-white">{item.question}</h3>
              <p class="mt-4 leading-7 text-white/60">{item.answer}</p>
            </article>
          ))}
        </div>
      </section>

      <footer class="mx-auto flex max-w-7xl flex-col gap-4 px-4 py-10 text-sm text-white/45 sm:px-6 md:flex-row md:items-center md:justify-between">
        <p>© 2026 ReasonableNoise. Premium sticker printing.</p>
        <div class="flex flex-wrap gap-5">
          <a href="/" class="hover:text-white">Home</a>
          <a href="/upload-design" class="hover:text-white">Upload Design</a>
          <a href="/usdot-stickers" class="hover:text-white">USDOT Stickers</a>
        </div>
      </footer>
    </main>
  </body>
</html>





