---
import "../styles/global.css";

const orderTypes = [
  "USDOT Sticker Pair - $29",
  "Extra USDOT Pair - $25",
  "One-Side USDOT Replacement - $18",
  "USDOT + Business Name Pair - $39",
  "Custom Business Decals - From $35",
  "Truck Door Lettering - From $69",
  "Fleet Lettering Package - From $59 / vehicle",
  "Logo Sticker Batch - From $35",
  "Design Cleanup / Layout Help - From $15",
];

const uploadOrderSteps = [
  "Submit your sticker details and artwork if available.",
  "Choose local pickup or shipping during checkout.",
  "Pay the secure order deposit through Stripe.",
  "Receive an order reference so we can prepare production.",
];

const uploadPageFaqs = [
  {
    q: "Can I upload artwork before checkout?",
    a: "Yes. You can upload your logo, artwork file, reference image, or design file before Stripe Checkout. Upload is optional, but it helps ReasonableNoise prepare your sticker order faster.",
  },
  {
    q: "Can I order USDOT stickers from this page?",
    a: "Yes. Choose USDOT Sticker Set as the sticker type, then enter your USDOT number, display name, size, quantity, color preference, and any notes.",
  },
  {
    q: "Can I choose pickup or shipping?",
    a: "Yes. You can choose local pickup with no shipping fee or choose shipping with standard shipping added during checkout.",
  },
  {
    q: "Is payment handled securely?",
    a: "Yes. ReasonableNoise uses Stripe Checkout for secure online order deposits.",
  },
];

const pricingGuideItems = [
  {
    name: "USDOT sticker pair",
    price: "$29",
    note: "Launch price for a standard pair. Normally $30.",
  },
  {
    name: "Extra USDOT pair",
    price: "$25",
    note: "Add another matching pair in the same order.",
  },
  {
    name: "One-side USDOT replacement",
    price: "$18",
    note: "Good for replacing one door decal.",
  },
  {
    name: "USDOT + business name pair",
    price: "$39",
    note: "USDOT number with company or legal business name.",
  },
  {
    name: "Custom business decals",
    price: "From $35",
    note: "Logo decals, simple business stickers, and custom vinyl decals.",
  },
  {
    name: "Truck door lettering",
    price: "From $69",
    note: "Business name, phone, website, and simple vehicle lettering.",
  },
  {
    name: "Fleet lettering",
    price: "From $59 / vehicle",
    note: "Available for 3 or more vehicles with matching layout.",
  },
  {
    name: "Logo sticker batches",
    price: "From $35",
    note: "Starter batch pricing for small logo sticker orders.",
  },
  {
    name: "Design cleanup",
    price: "From $15",
    note: "Basic file cleanup, layout help, or print prep.",
  },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Upload Artwork &amp; Start Custom Sticker Order | ReasonableNoise</title>
    <meta name="description" content="Upload artwork for USDOT stickers, custom decals, vehicle lettering, and fleet decals. Choose pickup or shipping and pay a secure Stripe order deposit." />
    <link rel="icon" type="image/png" href="/assets/rn-logo.png" />
    <link rel="shortcut icon" type="image/png" href="/assets/rn-logo.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
  
    <!-- RN-2I-A SEO START -->
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://reasonablenoise.com/upload-design/" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="ReasonableNoise" />
    <meta property="og:title" content="Upload Artwork &amp; Start Custom Sticker Order | ReasonableNoise" />
    <meta property="og:description" content="Start a secure ReasonableNoise sticker order, upload artwork, choose local pickup or shipping, and pay your order deposit through Stripe." />
    <meta property="og:url" content="https://reasonablenoise.com/upload-design/" />
    <meta property="og:image" content="https://reasonablenoise.com/assets/rn-logo.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Upload Design &amp; Start Sticker Order | ReasonableNoise" />
    <meta name="twitter:description" content="Start a secure ReasonableNoise sticker order, upload artwork, choose local pickup or shipping, and pay your order deposit through Stripe." />
    <meta name="twitter:image" content="https://reasonablenoise.com/assets/rn-logo.png" />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Service",
      name: "Custom sticker order and artwork upload",
      provider: {
        "@type": "Organization",
        name: "ReasonableNoise",
        url: "https://reasonablenoise.com",
      },
      serviceType: "Sticker printing, USDOT stickers, custom decals, vehicle lettering, and fleet decals",
      areaServed: "United States",
      url: "https://reasonablenoise.com/upload-design/",
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      mainEntity: uploadPageFaqs.map((item) => ({
        "@type": "Question",
        name: item.q,
        acceptedAnswer: {
          "@type": "Answer",
          text: item.a,
        },
      })),
    })} />
    <!-- RN-2I-A SEO END -->
  </head>

  <body class="min-h-screen bg-[#050608] text-white antialiased">
    <main class="relative overflow-hidden">
      <div class="absolute inset-0 -z-10">
        <div class="absolute left-1/2 top-0 h-[520px] w-[900px] -translate-x-1/2 rounded-full bg-blue-500/15 blur-[120px]"></div>
        <div class="absolute right-[-120px] top-[320px] h-[420px] w-[420px] rounded-full bg-cyan-400/10 blur-[100px]"></div>
      </div>

      <header class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-4 py-5 sm:px-6">
        <a href="/" class="flex items-center gap-3">
          <div class="flex h-16 w-16 items-center justify-center rounded-3xl bg-black p-2 shadow-lg shadow-black/30 ring-1 ring-white/10">
            <img
              src="/assets/rn-logo.png"
              alt="ReasonableNoise logo"
              class="h-full w-full object-contain"
            />
          </div>
          <div>
            <p class="text-sm font-semibold tracking-wide">ReasonableNoise</p>
            <p class="text-xs text-white/50">Premium sticker printing</p>
          </div>
        </a>

        <nav class="hidden items-center gap-8 text-sm text-white/70 md:flex">
          <a class="hover:text-white" href="/">Home</a>
          <a class="hover:text-white" href="/usdot-stickers">USDOT Stickers</a>
          <a class="text-white" href="/upload-design">Upload Design</a>
        </nav>

        <a
          href="#order-form"
          class="rounded-full border border-white/15 bg-white px-5 py-2.5 text-sm font-semibold text-black shadow-2xl shadow-white/10 transition hover:bg-white/90"
        >
          Start Order
        </a>
      </header>

      <section class="mx-auto grid max-w-7xl gap-8 px-4 pb-16 pt-8 sm:px-6 md:grid-cols-[0.9fr_1.1fr] md:gap-12 md:pb-28 md:pt-24">
        <div>
          <div class="mb-6 inline-flex rounded-full border border-white/10 bg-white/5 px-4 py-2 text-sm text-white/70 backdrop-blur">
            Secure artwork upload • USDOT stickers • custom decals
          </div>

          <h1 class="text-4xl font-semibold tracking-[-0.05em] sm:text-5xl md:text-7xl">
            Upload artwork and start your sticker order.
          </h1>

          <p class="mt-7 max-w-xl text-lg leading-8 text-white/65">
            Start a secure order for USDOT stickers, custom business decals, truck lettering, fleet decals, or logo sticker printing. Upload artwork now or send it later, then choose local pickup or shipping before paying the order deposit.
          </p>

          <div class="mt-10 grid gap-4">
            <div class="rounded-3xl border border-white/10 bg-white/[0.06] p-5 backdrop-blur">
              <p class="font-semibold">Local pickup</p>
              <p class="mt-2 text-sm leading-6 text-white/55">
                Choose this if you want to pick up locally. No shipping fee is added at checkout.
              </p>
            </div>

            <div class="rounded-3xl border border-white/10 bg-white/[0.06] p-5 backdrop-blur">
              <p class="font-semibold">Shipping</p>
              <p class="mt-2 text-sm leading-6 text-white/55">
                Choose this if you want the order mailed to you. Stripe will collect your shipping address and add standard shipping.
              </p>
            </div>

            <div class="rounded-3xl border border-white/10 bg-white/[0.06] p-5 backdrop-blur">
              <p class="font-semibold">Artwork upload</p>
              <p class="mt-2 text-sm leading-6 text-white/55">
                Upload is optional, but recommended. Your file is stored privately before checkout so we can prepare your order faster.
              </p>
            </div>
          </div>

          <div class="mt-6 rounded-3xl border border-white/10 bg-white/[0.06] p-5 backdrop-blur">
            <p class="font-semibold">What happens after checkout?</p>
            <ol class="mt-4 grid gap-3 text-sm leading-6 text-white/60">
              {uploadOrderSteps.map((step, index) => (
                <li class="flex gap-3">
                  <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-white text-xs font-bold text-black">
                    {index + 1}
                  </span>
                  <span>{step}</span>
                </li>
              ))}
            </ol>
          </div>
        </div>

        <form id="order-form" class="rounded-[2rem] border border-white/10 bg-white p-5 text-black shadow-2xl shadow-black/40 sm:rounded-[2.5rem] sm:p-6 md:p-8">
          <div class="mb-8">
            <p class="text-sm font-bold uppercase tracking-[0.3em] text-black/40">Order Request</p>
            <h2 class="mt-3 text-3xl font-semibold tracking-[-0.04em]">Pay order deposit.</h2>
            <p class="mt-3 text-sm leading-6 text-black/55">
              Select a file now or send it later. If you choose a file, we securely upload it before Stripe Checkout.
            </p>
            <p id="checkout-message" class="mt-4 hidden rounded-2xl border border-black/10 bg-black/[0.04] px-4 py-3 text-sm font-semibold"></p>
          </div>

          <div class="grid gap-4 md:grid-cols-2">
            <label class="grid gap-2">
              <span class="text-sm font-semibold text-black/70">Your name *</span>
              <input name="customerName" required class="rounded-2xl border border-black/10 bg-black/[0.03] px-4 py-3 outline-none focus:border-black/30" placeholder="Full name" />
            </label>

            <label class="grid gap-2">
              <span class="text-sm font-semibold text-black/70">Business name</span>
              <input name="businessName" class="rounded-2xl border border-black/10 bg-black/[0.03] px-4 py-3 outline-none focus:border-black/30" placeholder="Company name" />
            </label>

            <label class="grid gap-2">
              <span class="text-sm font-semibold text-black/70">Email *</span>
              <input name="email" required type="email" class="rounded-2xl border border-black/10 bg-black/[0.03] px-4 py-3 outline-none focus:border-black/30" placeholder="you@email.com" />
            </label>

            <label class="grid gap-2">
              <span class="text-sm font-semibold text-black/70">Phone</span>
              <input name="phone" class="rounded-2xl border border-black/10 bg-black/[0.03] px-4 py-3 outline-none focus:border-black/30" placeholder="Phone number" />
            </label>

            <label class="grid gap-2 md:col-span-2">
              <span class="text-sm font-semibold text-black/70">Fulfillment *</span>
              <select name="fulfillmentMethod" required class="rounded-2xl border border-black/10 bg-black/[0.03] px-4 py-3 outline-none focus:border-black/30">
                <option value="local_pickup">Local pickup - no shipping fee</option>
                <option value="shipping">Ship my order - standard shipping added</option>
              </select>
            </label>

            <label class="grid gap-2 md:col-span-2">
              <span class="text-sm font-semibold text-black/70">Sticker type / starting price</span>
              <select name="stickerType" class="rounded-2xl border border-black/10 bg-black/[0.03] px-4 py-3 outline-none focus:border-black/30">
                {orderTypes.map((type) => <option>{type}</option>)}
              </select>
            </label>

            <label class="grid gap-2">
              <span class="text-sm font-semibold text-black/70">USDOT number</span>
              <input name="usdotNumber" class="rounded-2xl border border-black/10 bg-black/[0.03] px-4 py-3 outline-none focus:border-black/30" placeholder="Example: 1234567" />
            </label>

            <label class="grid gap-2">
              <span class="text-sm font-semibold text-black/70">Display name on decal</span>
              <input name="decalDisplayName" class="rounded-2xl border border-black/10 bg-black/[0.03] px-4 py-3 outline-none focus:border-black/30" placeholder="Legal or business name" />
            </label>

            <label class="grid gap-2">
              <span class="text-sm font-semibold text-black/70">Size</span>
              <input name="size" class="rounded-2xl border border-black/10 bg-black/[0.03] px-4 py-3 outline-none focus:border-black/30" placeholder="Example: 12in x 24in" />
            </label>

            <label class="grid gap-2">
              <span class="text-sm font-semibold text-black/70">Quantity</span>
              <input name="quantity" type="number" min="1" class="rounded-2xl border border-black/10 bg-black/[0.03] px-4 py-3 outline-none focus:border-black/30" placeholder="2" />
            </label>

            <label class="grid gap-2">
              <span class="text-sm font-semibold text-black/70">Color preference</span>
              <input name="colorPreference" class="rounded-2xl border border-black/10 bg-black/[0.03] px-4 py-3 outline-none focus:border-black/30" placeholder="White, black, red, etc." />
            </label>

            <label class="grid gap-2">
              <span class="text-sm font-semibold text-black/70">Material</span>
              <select name="material" class="rounded-2xl border border-black/10 bg-black/[0.03] px-4 py-3 outline-none focus:border-black/30">
                <option>Outdoor vinyl</option>
                <option>Magnetic decal</option>
                <option>Not sure yet</option>
              </select>
            </label>

            <label class="grid gap-2 md:col-span-2">
              <span class="text-sm font-semibold text-black/70">Artwork or reference file</span>
              <div class="rounded-3xl border border-dashed border-black/20 bg-black/[0.03] p-6">
                <input id="artwork-file" name="artwork" type="file" accept=".png,.jpg,.jpeg,.webp,.pdf,.svg,.ai,.eps,.psd" class="w-full text-sm text-black/60" />
                <div id="artwork-status" class="mt-4 hidden rounded-2xl border border-black/10 bg-white px-4 py-3 text-sm font-semibold text-black/70"></div>
                <p class="mt-3 text-xs leading-5 text-black/45">
                  Optional today: upload your logo, artwork, reference image, or design file. Accepted: PNG, JPG, WEBP, PDF, SVG, AI, EPS, PSD. Max 15 MB.
                </p>
              </div>
            </label>

            <label class="grid gap-2 md:col-span-2">
              <span class="text-sm font-semibold text-black/70">Notes</span>
              <textarea name="notes" class="min-h-32 rounded-2xl border border-black/10 bg-black/[0.03] px-4 py-3 outline-none focus:border-black/30" placeholder="Tell us anything important about your order."></textarea>
            </label>
          </div>

          <div id="price-preview-card" aria-live="polite" class="mt-6 rounded-[1.5rem] border border-black/10 bg-black/[0.04] p-5">
            <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
              <div>
                <p class="text-xs font-bold uppercase tracking-[0.25em] text-black/40">Estimated checkout today</p>
                <p id="price-preview-label" class="mt-2 text-lg font-bold text-black">USDOT Sticker Pair</p>
                <p id="price-preview-detail" class="mt-2 text-sm leading-6 text-black/55">
                  Final price is confirmed after artwork, size, quantity, material, and production review.
                </p>
              </div>
              <p id="price-preview-total" class="text-3xl font-bold tracking-[-0.04em] text-black">$29.00</p>
            </div>

            <div class="mt-5 grid gap-2 text-sm text-black/60">
              <div class="flex items-center justify-between gap-4">
                <span>Selected item</span>
                <span id="price-preview-base" class="font-semibold text-black">$29.00</span>
              </div>
              <div class="flex items-center justify-between gap-4">
                <span>Fulfillment</span>
                <span id="price-preview-shipping" class="font-semibold text-black">Local pickup: $0.00</span>
              </div>
            </div>

            <p class="mt-4 text-xs leading-5 text-black/45">
              Standard shipping is estimated at $9.99. Large order shipping is estimated at $14.99. Oversized or special packaging may be confirmed after review.
            </p>
          </div>

          <button
            id="checkout-button"
            type="submit"
            class="mt-6 w-full rounded-full bg-black px-6 py-4 text-sm font-bold text-white shadow-xl shadow-black/20 transition hover:bg-black/90"
          >
            Continue to Secure Stripe Checkout
          </button>
        </form>
      </section>

      <section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 md:py-16">
        <div class="rounded-[2.5rem] border border-white/10 bg-white/[0.06] p-5 backdrop-blur sm:p-8 md:p-12">
          <div class="mb-8">
            <p class="text-sm font-semibold uppercase tracking-[0.3em] text-cyan-300">Pricing Guide</p>
            <h2 class="mt-4 max-w-3xl text-4xl font-semibold tracking-[-0.04em] md:text-5xl">
              Simple pricing before checkout.
            </h2>
            <p class="mt-4 max-w-3xl leading-7 text-white/60">
              Use this as a starting guide for USDOT stickers, custom decals, truck lettering, and fleet orders. Your checkout payment is an order deposit; final pricing is confirmed after artwork, size, quantity, material, and production review.
            </p>
          </div>

          <div class="grid gap-4 md:grid-cols-3">
            {pricingGuideItems.map((item) => (
              <article class="rounded-3xl border border-white/10 bg-black/20 p-5">
                <p class="text-sm font-semibold text-white/55">{item.name}</p>
                <p class="mt-3 text-3xl font-bold tracking-[-0.04em] text-white">{item.price}</p>
                <p class="mt-3 text-sm leading-6 text-white/55">{item.note}</p>
              </article>
            ))}
          </div>

          <div class="mt-7 rounded-3xl border border-cyan-300/20 bg-cyan-300/10 p-5">
            <p class="text-sm font-semibold uppercase tracking-[0.25em] text-cyan-200">Launch offer</p>
            <p class="mt-3 leading-7 text-white/70">
              USDOT sticker pairs start at $29 for a limited launch price. Standard deposit is paid online, and any remaining balance is confirmed after order review.
            </p>
          </div>
        </div>
      </section>

      <section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 md:py-16">
        <div class="rounded-[2.5rem] border border-white/10 bg-white/[0.06] p-5 backdrop-blur sm:p-8 md:p-12">
          <div class="mb-8">
            <p class="text-sm font-semibold uppercase tracking-[0.3em] text-cyan-300">Order Details</p>
            <h2 class="mt-4 max-w-3xl text-4xl font-semibold tracking-[-0.04em] md:text-5xl">
              What to include with your order.
            </h2>
          </div>

          <div class="grid gap-4 md:grid-cols-3">
            <article class="rounded-3xl border border-white/10 bg-black/20 p-5">
              <h3 class="font-bold text-white">USDOT sticker orders</h3>
              <p class="mt-3 text-sm leading-6 text-white/55">
                Add your USDOT number, company or legal name, decal size, quantity, color preference, and vehicle type.
              </p>
            </article>

            <article class="rounded-3xl border border-white/10 bg-black/20 p-5">
              <h3 class="font-bold text-white">Custom decal orders</h3>
              <p class="mt-3 text-sm leading-6 text-white/55">
                Upload your logo or design file, or describe what you want printed if you need layout help.
              </p>
            </article>

            <article class="rounded-3xl border border-white/10 bg-black/20 p-5">
              <h3 class="font-bold text-white">Pickup or shipping</h3>
              <p class="mt-3 text-sm leading-6 text-white/55">
                Choose local pickup with no shipping fee or shipping with address collection during checkout.
              </p>
            </article>
          </div>
        </div>
      </section>


      <section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 md:py-16">
        <div class="rounded-[2.5rem] border border-white/10 bg-white/[0.06] p-5 backdrop-blur sm:p-8 md:p-12">
          <div class="mb-8">
            <p class="text-sm font-semibold uppercase tracking-[0.3em] text-cyan-300">Coming Soon</p>
            <h2 class="mt-4 max-w-3xl text-4xl font-semibold tracking-[-0.04em] md:text-5xl">
              DTF shirts are coming soon.
            </h2>
            <p class="mt-4 max-w-3xl leading-7 text-white/60">
              Custom DTF T-shirt printing is being prepared for logo shirts, event shirts, work shirts, and small business apparel. This service is quote-only for now and is not enabled for paid checkout yet.
            </p>
          </div>

          <div class="grid gap-4 md:grid-cols-4">
            <article class="rounded-3xl border border-white/10 bg-black/20 p-5">
              <p class="text-sm font-semibold text-white/55">Single shirt</p>
              <p class="mt-3 text-3xl font-bold tracking-[-0.04em] text-white">From $24</p>
              <p class="mt-3 text-sm leading-6 text-white/55">Best for one-off custom shirt requests.</p>
            </article>

            <article class="rounded-3xl border border-white/10 bg-black/20 p-5">
              <p class="text-sm font-semibold text-white/55">Small batch 6+</p>
              <p class="mt-3 text-3xl font-bold tracking-[-0.04em] text-white">From $20</p>
              <p class="mt-3 text-sm leading-6 text-white/55">Estimated per-shirt price for small batches.</p>
            </article>

            <article class="rounded-3xl border border-white/10 bg-black/20 p-5">
              <p class="text-sm font-semibold text-white/55">Bulk 12+</p>
              <p class="mt-3 text-3xl font-bold tracking-[-0.04em] text-white">From $18</p>
              <p class="mt-3 text-sm leading-6 text-white/55">Estimated per-shirt price for larger runs.</p>
            </article>

            <article class="rounded-3xl border border-white/10 bg-black/20 p-5">
              <p class="text-sm font-semibold text-white/55">Front + back</p>
              <p class="mt-3 text-3xl font-bold tracking-[-0.04em] text-white">Quote</p>
              <p class="mt-3 text-sm leading-6 text-white/55">Final pricing depends on artwork, print size, and quantity.</p>
            </article>
          </div>

          <div class="mt-7 rounded-3xl border border-cyan-300/20 bg-cyan-300/10 p-5">
            <p class="text-sm font-semibold uppercase tracking-[0.25em] text-cyan-200">Not checkout-enabled yet</p>
            <p class="mt-3 leading-7 text-white/70">
              DTF T-shirt printing is shown as a coming soon service only. Sticker and decal orders remain available for secure checkout.
            </p>
          </div>
        </div>
      </section>

      <footer class="mx-auto flex max-w-7xl flex-col gap-4 px-4 py-10 text-sm text-white/45 sm:px-6 md:flex-row md:items-center md:justify-between">
        <p>© 2026 ReasonableNoise. Premium sticker printing.</p>
        <div class="flex flex-wrap gap-5">
          <a href="/" class="hover:text-white">Home</a>
          <a href="/usdot-stickers" class="hover:text-white">USDOT Stickers</a>
          <a href="/privacy" class="hover:text-white">Privacy</a>
          <a href="/terms" class="hover:text-white">Terms</a>
        </div>
      </footer>
    </main>

    <script>
      const form = document.getElementById("order-form");
      const button = document.getElementById("checkout-button");
      const message = document.getElementById("checkout-message");
      const artworkInput = document.getElementById("artwork-file");
      const artworkStatus = document.getElementById("artwork-status");
      const ARTWORK_REQUIRED = false;
      const STANDARD_SHIPPING_PREVIEW_CENTS = 999;
      const LARGE_SHIPPING_PREVIEW_CENTS = 1499;

      const PRICE_PREVIEW_OPTIONS = [
        {
          match: ["extra usdot"],
          label: "Extra USDOT Pair",
          amountCents: 2500,
        },
        {
          match: ["one-side", "one side", "replacement"],
          label: "One-Side USDOT Replacement",
          amountCents: 1800,
        },
        {
          match: ["usdot + business", "usdot plus business", "business name pair"],
          label: "USDOT + Business Name Pair",
          amountCents: 3900,
        },
        {
          match: ["truck door"],
          label: "Truck Door Lettering",
          amountCents: 6900,
        },
        {
          match: ["fleet"],
          label: "Fleet Lettering Package",
          amountCents: 5900,
        },
        {
          match: ["logo sticker batch", "logo / artwork", "logo artwork", "artwork printing"],
          label: "Logo Sticker Batch",
          amountCents: 3500,
        },
        {
          match: ["design cleanup", "design help"],
          label: "Design Cleanup / Layout Help",
          amountCents: 1500,
        },
        {
          match: ["custom business", "custom decal"],
          label: "Custom Business Decals",
          amountCents: 3500,
        },
        {
          match: ["usdot"],
          label: "USDOT Sticker Pair",
          amountCents: 2900,
        },
      ];

      const stickerTypeInput = form?.elements?.stickerType;
      const fulfillmentMethodInput = form?.elements?.fulfillmentMethod;
      const quantityInput = form?.elements?.quantity;
      const sizeInput = form?.elements?.size;
      const notesInput = form?.elements?.notes;
      const pricePreviewLabel = document.getElementById("price-preview-label");
      const pricePreviewDetail = document.getElementById("price-preview-detail");
      const pricePreviewTotal = document.getElementById("price-preview-total");
      const pricePreviewBase = document.getElementById("price-preview-base");
      const pricePreviewShipping = document.getElementById("price-preview-shipping");

      function formatMoneyFromCents(cents) {
        return new Intl.NumberFormat("en-US", {
          style: "currency",
          currency: "USD",
        }).format(Number(cents || 0) / 100);
      }

      function resolvePricePreview(stickerType) {
        const normalized = String(stickerType || "").toLowerCase();
        const selected = PRICE_PREVIEW_OPTIONS.find((option) =>
          option.match.some((needle) => normalized.includes(needle))
        );

        return selected || {
          label: "Custom Sticker Order",
          amountCents: 2500,
        };
      }

      function resolveShippingPreview(selected) {
        const combined = [
          stickerTypeInput?.value || "",
          selected?.label || "",
          quantityInput?.value || "",
          sizeInput?.value || "",
          notesInput?.value || "",
        ]
          .join(" ")
          .toLowerCase();

        const quantityNumber = Number.parseInt(String(quantityInput?.value || ""), 10);

        const largeOrderSignals = [
          "truck door",
          "fleet",
          "logo sticker batch",
          "large decal",
          "large order",
          "oversized",
          "multi-vehicle",
          "multiple vehicles",
          "trailer lettering",
          "vehicle lettering",
          "yard sign",
          "banner",
        ];

        const isLargeOrder =
          largeOrderSignals.some((signal) => combined.includes(signal)) ||
          (Number.isFinite(quantityNumber) && quantityNumber >= 20);

        return isLargeOrder
          ? {
              label: "Large order shipping",
              amountCents: LARGE_SHIPPING_PREVIEW_CENTS,
            }
          : {
              label: "Standard shipping",
              amountCents: STANDARD_SHIPPING_PREVIEW_CENTS,
            };
      }

      function getPricePreview() {
        const selected = resolvePricePreview(stickerTypeInput?.value || "");
        const isShipping = fulfillmentMethodInput?.value === "shipping";
        const shipping = isShipping
          ? resolveShippingPreview(selected)
          : {
              label: "Local pickup",
              amountCents: 0,
            };

        return {
          ...selected,
          isShipping,
          shippingLabel: shipping.label,
          shippingCents: shipping.amountCents,
          totalCents: selected.amountCents + shipping.amountCents,
        };
      }

      function updatePricePreview() {
        const preview = getPricePreview();

        if (pricePreviewLabel) {
          pricePreviewLabel.textContent = preview.label;
        }

        if (pricePreviewTotal) {
          pricePreviewTotal.textContent = formatMoneyFromCents(preview.totalCents);
        }

        if (pricePreviewBase) {
          pricePreviewBase.textContent = formatMoneyFromCents(preview.amountCents);
        }

        if (pricePreviewShipping) {
          pricePreviewShipping.textContent = preview.isShipping
            ? `${preview.shippingLabel}: ${formatMoneyFromCents(preview.shippingCents)}`
            : "Local pickup: $0.00";
        }

        if (pricePreviewDetail) {
          pricePreviewDetail.textContent = preview.isShipping
            ? `Includes ${preview.shippingLabel.toLowerCase()} estimate. Final price is confirmed after artwork, size, quantity, material, and production review.`
            : "Local pickup selected. Final price is confirmed after artwork, size, quantity, material, and production review.";
        }

        if (button && !button.disabled) {
          button.textContent = `Continue to Secure Stripe Checkout (${formatMoneyFromCents(preview.totalCents)})`;
        }
      }

      function showMessage(text, isError = false) {
        if (!message) return;
        message.textContent = text;
        message.classList.remove("hidden");
        message.classList.toggle("text-red-600", isError);
      }

      function formatFileSize(bytes) {
        const size = Number(bytes || 0);
        if (!Number.isFinite(size) || size <= 0) return "";
        if (size < 1024) return `${size} B`;
        if (size < 1024 * 1024) return `${Math.round(size / 1024)} KB`;
        return `${(size / (1024 * 1024)).toFixed(1)} MB`;
      }

      function showArtworkStatus(text, mode = "info") {
        if (!artworkStatus) return;

        artworkStatus.textContent = text;
        artworkStatus.classList.remove("hidden", "text-red-700", "text-emerald-700", "text-black/70");
        artworkStatus.classList.add(
          mode === "error" ? "text-red-700" : mode === "success" ? "text-emerald-700" : "text-black/70"
        );
      }

      stickerTypeInput?.addEventListener("change", updatePricePreview);
      fulfillmentMethodInput?.addEventListener("change", updatePricePreview);
      quantityInput?.addEventListener("input", updatePricePreview);
      sizeInput?.addEventListener("input", updatePricePreview);
      notesInput?.addEventListener("input", updatePricePreview);
      updatePricePreview();

      artworkInput?.addEventListener("change", () => {
        const file = artworkInput.files?.[0];

        if (!file) {
          showArtworkStatus("No artwork selected yet. You can continue and send artwork later.");
          return;
        }

        showArtworkStatus(`Artwork selected: ${file.name} (${formatFileSize(file.size)})`);
      });

      form?.addEventListener("submit", async (event) => {
        event.preventDefault();

        button.disabled = true;
        button.textContent = "Creating secure checkout...";
        showMessage("Preparing Stripe Checkout...");

        const formData = new FormData(form);
        const payload = Object.fromEntries(formData.entries());

        try {
          const artworkFile = artworkInput?.files?.[0];

          if (ARTWORK_REQUIRED && !artworkFile) {
            throw new Error("Please upload your artwork or reference file before checkout.");
          }

          if (!artworkFile) {
            showArtworkStatus("No artwork selected. You can still checkout and send artwork later.");
          }

          if (artworkFile) {
            button.textContent = "Uploading artwork securely...";
            showMessage("Uploading artwork securely...");

            const uploadData = new FormData();
            uploadData.append("artwork", artworkFile);

            const uploadResponse = await fetch("/api/upload-artwork", {
              method: "POST",
              body: uploadData,
            });

            const uploadResult = await uploadResponse.json();

            if (!uploadResponse.ok || !uploadResult.success) {
              throw new Error(uploadResult.error || "Unable to upload artwork.");
            }

            payload.artworkObjectKey = uploadResult.artworkObjectKey;
            payload.artworkFilename = uploadResult.artworkFilename;
            payload.artworkSize = String(uploadResult.artworkSize || "");
            payload.artworkType = uploadResult.artworkType;
            payload.uploadId = uploadResult.uploadId;

            button.textContent = "Artwork uploaded. Preparing checkout...";
            showArtworkStatus(`Artwork uploaded securely: ${uploadResult.artworkFilename || artworkFile.name}`, "success");
            showMessage("Artwork uploaded. Preparing Stripe Checkout...");
          }

          const response = await fetch("/api/create-checkout-session", {
            method: "POST",
            headers: {
              "content-type": "application/json",
            },
            body: JSON.stringify(payload),
          });

          const data = await response.json();

          if (!response.ok || !data.success || !data.url) {
            throw new Error(data.error || "Unable to start checkout.");
          }

          window.location.href = data.url;
        } catch (error) {
          showMessage(error.message || "Unable to start checkout.", true);
          button.disabled = false;
          updatePricePreview();
        }
      });
    </script>
  </body>
</html>







