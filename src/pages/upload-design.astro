---
import "../styles/global.css";

const orderTypes = [
  "USDOT Sticker Set",
  "Custom Business Decals",
  "Fleet Lettering Package",
  "Logo / Artwork Printing",
  "Design Help Needed",
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Upload Design | ReasonableNoise</title>
    <meta
      name="description"
      content="Upload your design or request premium USDOT stickers, custom decals, and business sticker printing from ReasonableNoise."
    />
  </head>

  <body class="min-h-screen bg-[#050608] text-white antialiased">
    <main class="relative overflow-hidden">
      <div class="absolute inset-0 -z-10">
        <div class="absolute left-1/2 top-0 h-[520px] w-[900px] -translate-x-1/2 rounded-full bg-blue-500/15 blur-[120px]"></div>
        <div class="absolute right-[-120px] top-[320px] h-[420px] w-[420px] rounded-full bg-cyan-400/10 blur-[100px]"></div>
      </div>

      <header class="mx-auto flex max-w-7xl items-center justify-between px-6 py-6">
        <a href="/" class="flex items-center gap-3">
          <div class="flex h-10 w-10 items-center justify-center rounded-2xl bg-white text-sm font-black text-black">
            RN
          </div>
          <div>
            <p class="text-sm font-semibold tracking-wide">ReasonableNoise</p>
            <p class="text-xs text-white/50">Premium sticker printing</p>
          </div>
        </a>

        <nav class="hidden items-center gap-8 text-sm text-white/70 md:flex">
          <a class="hover:text-white" href="/">Home</a>
          <a class="hover:text-white" href="/usdot-stickers">USDOT Stickers</a>
          <a class="text-white" href="/upload-design">Upload Design</a>
        </nav>

        <a
          href="#order-form"
          class="rounded-full border border-white/15 bg-white px-5 py-2.5 text-sm font-semibold text-black shadow-2xl shadow-white/10 transition hover:bg-white/90"
        >
          Start Order
        </a>
      </header>

      <section class="mx-auto grid max-w-7xl gap-12 px-6 pb-20 pt-16 md:grid-cols-[0.9fr_1.1fr] md:pb-28 md:pt-24">
        <div>
          <div class="mb-6 inline-flex rounded-full border border-white/10 bg-white/5 px-4 py-2 text-sm text-white/70 backdrop-blur">
            Upload artwork • request print • pay online soon
          </div>

          <h1 class="text-5xl font-semibold tracking-[-0.05em] md:text-7xl">
            Upload your design or start a sticker order.
          </h1>

          <p class="mt-7 max-w-xl text-lg leading-8 text-white/65">
            Send your artwork, USDOT details, size, color, and quantity. The live upload and Stripe payment flow will connect in the next phase.
          </p>

          <div class="mt-10 grid gap-4">
            <div class="rounded-3xl border border-white/10 bg-white/[0.06] p-5 backdrop-blur">
              <p class="font-semibold">1. Submit details</p>
              <p class="mt-2 text-sm leading-6 text-white/55">Tell us what type of sticker or decal you need.</p>
            </div>

            <div class="rounded-3xl border border-white/10 bg-white/[0.06] p-5 backdrop-blur">
              <p class="font-semibold">2. Upload artwork</p>
              <p class="mt-2 text-sm leading-6 text-white/55">Send a logo, design file, reference image, or instructions.</p>
            </div>

            <div class="rounded-3xl border border-white/10 bg-white/[0.06] p-5 backdrop-blur">
              <p class="font-semibold">3. Print-ready checkout</p>
              <p class="mt-2 text-sm leading-6 text-white/55">Stripe payment and secure file storage will be added in RN-2.</p>
            </div>
          </div>
        </div>

        <form id="order-form" class="rounded-[2.5rem] border border-white/10 bg-white p-6 text-black shadow-2xl shadow-black/40 md:p-8">
          <div class="mb-8">
            <p class="text-sm font-bold uppercase tracking-[0.3em] text-black/40">Order Request</p>
            <h2 class="mt-3 text-3xl font-semibold tracking-[-0.04em]">Tell us what to print.</h2>
            <p class="mt-3 text-sm leading-6 text-black/55">
              This form is currently front-end only. Backend upload, order storage, and Stripe Checkout come next.
            </p>
          </div>

          <div class="grid gap-4 md:grid-cols-2">
            <label class="grid gap-2">
              <span class="text-sm font-semibold text-black/70">Your name</span>
              <input class="rounded-2xl border border-black/10 bg-black/[0.03] px-4 py-3 outline-none focus:border-black/30" placeholder="Full name" />
            </label>

            <label class="grid gap-2">
              <span class="text-sm font-semibold text-black/70">Business name</span>
              <input class="rounded-2xl border border-black/10 bg-black/[0.03] px-4 py-3 outline-none focus:border-black/30" placeholder="Company name" />
            </label>

            <label class="grid gap-2">
              <span class="text-sm font-semibold text-black/70">Email</span>
              <input type="email" class="rounded-2xl border border-black/10 bg-black/[0.03] px-4 py-3 outline-none focus:border-black/30" placeholder="you@email.com" />
            </label>

            <label class="grid gap-2">
              <span class="text-sm font-semibold text-black/70">Phone</span>
              <input class="rounded-2xl border border-black/10 bg-black/[0.03] px-4 py-3 outline-none focus:border-black/30" placeholder="Phone number" />
            </label>

            <label class="grid gap-2 md:col-span-2">
              <span class="text-sm font-semibold text-black/70">Sticker type</span>
              <select class="rounded-2xl border border-black/10 bg-black/[0.03] px-4 py-3 outline-none focus:border-black/30">
                {orderTypes.map((type) => <option>{type}</option>)}
              </select>
            </label>

            <label class="grid gap-2">
              <span class="text-sm font-semibold text-black/70">USDOT number</span>
              <input class="rounded-2xl border border-black/10 bg-black/[0.03] px-4 py-3 outline-none focus:border-black/30" placeholder="Example: 1234567" />
            </label>

            <label class="grid gap-2">
              <span class="text-sm font-semibold text-black/70">Display name on decal</span>
              <input class="rounded-2xl border border-black/10 bg-black/[0.03] px-4 py-3 outline-none focus:border-black/30" placeholder="Legal or business name" />
            </label>

            <label class="grid gap-2">
              <span class="text-sm font-semibold text-black/70">Size</span>
              <input class="rounded-2xl border border-black/10 bg-black/[0.03] px-4 py-3 outline-none focus:border-black/30" placeholder="Example: 12in x 24in" />
            </label>

            <label class="grid gap-2">
              <span class="text-sm font-semibold text-black/70">Quantity</span>
              <input type="number" min="1" class="rounded-2xl border border-black/10 bg-black/[0.03] px-4 py-3 outline-none focus:border-black/30" placeholder="2" />
            </label>

            <label class="grid gap-2">
              <span class="text-sm font-semibold text-black/70">Color preference</span>
              <input class="rounded-2xl border border-black/10 bg-black/[0.03] px-4 py-3 outline-none focus:border-black/30" placeholder="White, black, red, etc." />
            </label>

            <label class="grid gap-2">
              <span class="text-sm font-semibold text-black/70">Material</span>
              <select class="rounded-2xl border border-black/10 bg-black/[0.03] px-4 py-3 outline-none focus:border-black/30">
                <option>Outdoor vinyl</option>
                <option>Magnetic decal</option>
                <option>Not sure yet</option>
              </select>
            </label>

            <label class="grid gap-2 md:col-span-2">
              <span class="text-sm font-semibold text-black/70">Upload artwork or reference file</span>
              <div class="rounded-3xl border border-dashed border-black/20 bg-black/[0.03] p-6">
                <input type="file" class="w-full text-sm text-black/60" />
                <p class="mt-3 text-xs leading-5 text-black/45">
                  RN-2 will connect this to secure Cloudflare R2 uploads.
                </p>
              </div>
            </label>

            <label class="grid gap-2 md:col-span-2">
              <span class="text-sm font-semibold text-black/70">Notes</span>
              <textarea class="min-h-32 rounded-2xl border border-black/10 bg-black/[0.03] px-4 py-3 outline-none focus:border-black/30" placeholder="Tell us anything important about your order."></textarea>
            </label>
          </div>

          <button
            type="button"
            class="mt-6 w-full rounded-full bg-black px-6 py-4 text-sm font-bold text-white shadow-xl shadow-black/20 transition hover:bg-black/90"
          >
            Submit + Pay Coming Next
          </button>
        </form>
      </section>

      <footer class="mx-auto flex max-w-7xl flex-col gap-4 px-6 py-10 text-sm text-white/45 md:flex-row md:items-center md:justify-between">
        <p>© 2026 ReasonableNoise. Premium sticker printing.</p>
        <div class="flex gap-5">
          <a href="/" class="hover:text-white">Home</a>
          <a href="/usdot-stickers" class="hover:text-white">USDOT Stickers</a>
          <a href="/upload-design" class="hover:text-white">Upload Design</a>
        </div>
      </footer>
    </main>
  </body>
</html>
