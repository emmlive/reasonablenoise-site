---
import "../styles/global.css";

const faqs = [
  {
    q: "What does ReasonableNoise make?",
    a: "ReasonableNoise prints premium USDOT stickers, custom business decals, vehicle lettering, fleet decals, truck stickers, logo stickers, and other custom vinyl sticker products.",
  },
  {
    q: "Do you make USDOT number stickers?",
    a: "Yes. USDOT sticker sets are one of our main services. You can send your company name, USDOT number, preferred size, color, quantity, and vehicle type.",
  },
  {
    q: "What information do I need for a USDOT sticker order?",
    a: "For USDOT stickers, include your legal business name or company name, USDOT number, preferred decal size, color, quantity, and whether the stickers are for a truck, trailer, van, or fleet vehicle.",
  },
  {
    q: "Can I upload my own design or logo?",
    a: "Yes. You can securely upload your logo, artwork file, reference image, or written design instructions through the upload order form before checkout.",
  },
  {
    q: "Can I pay online?",
    a: "Yes. ReasonableNoise uses Stripe Checkout for secure online order deposits. You can choose local pickup or shipping during the order flow.",
  },
  {
    q: "Do you offer pickup or shipping?",
    a: "Yes. You can choose local pickup with no shipping fee or select shipping during checkout. Shipping address collection is handled securely during checkout when shipping is selected.",
  },
  {
    q: "Do you help with design layout?",
    a: "Yes. If you do not have a print-ready design, you can provide the details you want printed and request layout help before production.",
  },
  {
    q: "Can you make decals for multiple trucks or fleet vehicles?",
    a: "Yes. ReasonableNoise can help prepare matching USDOT decals, commercial truck lettering, trailer decals, van decals, and fleet branding for multiple vehicles.",
  },
  {
    q: "What happens after I place an order?",
    a: "After checkout, ReasonableNoise receives your order details, artwork information, pickup or shipping preference, and order reference. We use that information to prepare the sticker order for production.",
  },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>FAQ | ReasonableNoise Sticker Orders</title>
    <meta name="description" content="Frequently asked questions about ReasonableNoise USDOT stickers, custom decals, artwork uploads, pickup, shipping, and order deposits." />
    <link rel="icon" type="image/png" href="/assets/rn-logo.png" />
    <link rel="shortcut icon" type="image/png" href="/assets/rn-logo.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
  
    <!-- RN-2I-A SEO START -->
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://reasonablenoise.com/faq/" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="ReasonableNoise" />
    <meta property="og:title" content="FAQ | ReasonableNoise Sticker Orders" />
    <meta property="og:description" content="Frequently asked questions about ReasonableNoise USDOT stickers, custom decals, artwork uploads, pickup, shipping, and order deposits." />
    <meta property="og:url" content="https://reasonablenoise.com/faq/" />
    <meta property="og:image" content="https://reasonablenoise.com/assets/rn-logo.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="FAQ | ReasonableNoise Sticker Orders" />
    <meta name="twitter:description" content="Frequently asked questions about ReasonableNoise USDOT stickers, custom decals, artwork uploads, pickup, shipping, and order deposits." />
    <meta name="twitter:image" content="https://reasonablenoise.com/assets/rn-logo.png" />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      mainEntity: faqs.map((item) => ({
        "@type": "Question",
        name: item.q,
        acceptedAnswer: {
          "@type": "Answer",
          text: item.a,
        },
      })),
    })} />
    <!-- RN-2I-A SEO END -->
  </head>

  <body class="min-h-screen bg-[#050608] text-white antialiased">
    <main class="relative overflow-hidden">
      <div class="absolute inset-0 -z-10">
        <div class="absolute left-1/2 top-0 h-[520px] w-[900px] -translate-x-1/2 rounded-full bg-cyan-500/15 blur-[120px]"></div>
      </div>

      <header class="mx-auto flex max-w-7xl items-center justify-between px-6 py-6">
        <a href="/" class="flex items-center gap-3">
          <div class="flex h-16 w-16 items-center justify-center rounded-3xl bg-black p-2 shadow-lg shadow-black/30 ring-1 ring-white/10">
            <img
              src="/assets/rn-logo.png"
              alt="ReasonableNoise logo"
              class="h-full w-full object-contain"
            />
          </div>
          <div>
            <p class="text-sm font-semibold tracking-wide">ReasonableNoise</p>
            <p class="text-xs text-white/50">Premium sticker printing</p>
          </div>
        </a>

        <nav class="hidden items-center gap-8 text-sm text-white/70 md:flex">
          <a class="hover:text-white" href="/">Home</a>
          <a class="hover:text-white" href="/usdot-stickers">USDOT Stickers</a>
          <a class="hover:text-white" href="/upload-design">Upload Design</a>
        </nav>

        <a href="/upload-design" class="rounded-full bg-white px-5 py-2.5 text-sm font-semibold text-black">
          Start Order
        </a>
      </header>

      <section class="mx-auto max-w-5xl px-4 py-16 sm:px-6 md:py-24">
        <p class="text-sm font-semibold uppercase tracking-[0.3em] text-cyan-300">FAQ</p>
        <h1 class="mt-5 text-5xl font-semibold tracking-[-0.05em] md:text-7xl">
          Questions before you print?
        </h1>
        <p class="mt-6 max-w-2xl text-lg leading-8 text-white/60">
          Answers about ordering USDOT stickers, custom decals, artwork uploads, pickup, shipping, online deposits, and fleet vehicle lettering.
        </p>

        <div class="mt-12 grid gap-4">
          {faqs.map((item) => (
            <article class="rounded-[2rem] border border-white/10 bg-white/[0.06] p-7 backdrop-blur">
              <h2 class="text-xl font-semibold">{item.q}</h2>
              <p class="mt-3 leading-7 text-white/60">{item.a}</p>
            </article>
          ))}
        </div>

        <div class="mt-12 rounded-[2rem] border border-white/10 bg-white p-7 text-black md:p-9">
          <p class="text-sm font-bold uppercase tracking-[0.25em] text-black/50">Start your order</p>
          <h2 class="mt-4 text-3xl font-semibold tracking-[-0.04em] md:text-4xl">
            Ready to start your sticker order?
          </h2>
          <p class="mt-4 max-w-2xl leading-7 text-black/60">
            Upload your artwork, request USDOT stickers, choose pickup or shipping, and complete your secure order deposit online.
          </p>
          <div class="mt-7 flex flex-col gap-3 sm:flex-row">
            <a href="/upload-design" class="rounded-full bg-black px-6 py-3 text-center text-sm font-bold text-white">
              Upload Design
            </a>
            <a href="/usdot-stickers" class="rounded-full border border-black/10 px-6 py-3 text-center text-sm font-bold text-black">
              View USDOT Stickers
            </a>
          </div>
        </div>
      </section>

      <footer class="mx-auto flex max-w-7xl flex-col gap-4 px-4 py-10 text-sm text-white/45 sm:px-6 md:flex-row md:items-center md:justify-between">
        <p>© 2026 ReasonableNoise. Premium sticker printing.</p>
        <div class="flex flex-wrap gap-5">
          <a href="/privacy" class="hover:text-white">Privacy</a>
          <a href="/terms" class="hover:text-white">Terms</a>
          <a href="/upload-design" class="hover:text-white">Contact</a>
        </div>
      </footer>
    </main>
  </body>
</html>





