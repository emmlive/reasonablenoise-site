---
import "../styles/global.css";
import WhatsAppChat from "../components/WhatsAppChat.astro";

const products = [
  {
    title: "USDOT Sticker Sets",
    text: "Clean, compliant-looking USDOT number decals for trucks, trailers, and commercial vehicles.",
  },
  {
    title: "Custom Business Decals",
    text: "Upload your logo, artwork, or idea and get premium vinyl stickers made for your brand.",
  },
  {
    title: "Fleet Lettering",
    text: "Consistent vehicle branding for multiple trucks, vans, trailers, and service vehicles.",
  },
];

const steps = [
  "Choose your sticker type",
  "Send your USDOT number or design",
  "Approve the layout",
  "We print and prepare your order",
];

const homeSeoFaqs = [
  {
    question: "What does ReasonableNoise make?",
    answer:
      "ReasonableNoise makes premium USDOT stickers, custom business decals, commercial vehicle lettering, fleet decals, and vinyl stickers for brands and working vehicles.",
  },
  {
    question: "Can I order custom decals with my logo?",
    answer:
      "Yes. You can upload your logo, artwork, reference image, or design file through the secure upload order form.",
  },
  {
    question: "Can ReasonableNoise make decals for trucks and fleets?",
    answer:
      "Yes. ReasonableNoise can prepare USDOT number decals, truck lettering, trailer decals, van decals, and matching fleet branding for multiple vehicles.",
  },
];

---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>ReasonableNoise | Premium USDOT Stickers &amp; Custom Decals</title>
    <meta name="description" content="Order premium USDOT stickers, custom decals, business stickers, and fleet lettering for commercial vehicles and brands." />
    <link rel="icon" type="image/png" href="/assets/rn-logo.png" />
    <link rel="shortcut icon" type="image/png" href="/assets/rn-logo.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
  
    <!-- RN-2I-A SEO START -->
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://reasonablenoise.com/" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="ReasonableNoise" />
    <meta property="og:title" content="ReasonableNoise | Premium USDOT Stickers &amp; Custom Decals" />
    <meta property="og:description" content="Order premium USDOT stickers, custom decals, business stickers, and fleet lettering for commercial vehicles and brands." />
    <meta property="og:url" content="https://reasonablenoise.com/" />
    <meta property="og:image" content="https://reasonablenoise.com/assets/rn-logo.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="ReasonableNoise | Premium USDOT Stickers &amp; Custom Decals" />
    <meta name="twitter:description" content="Order premium USDOT stickers, custom decals, business stickers, and fleet lettering for commercial vehicles and brands." />
    <meta name="twitter:image" content="https://reasonablenoise.com/assets/rn-logo.png" />
    <script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "ReasonableNoise",
  "url": "https://reasonablenoise.com",
  "logo": "https://reasonablenoise.com/assets/rn-logo.png",
  "description": "ReasonableNoise creates premium USDOT stickers, custom decals, business stickers, and fleet lettering."
}
    </script>
    <script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "ReasonableNoise",
  "url": "https://reasonablenoise.com"
}
    </script>
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      mainEntity: homeSeoFaqs.map((item) => ({
        "@type": "Question",
        name: item.question,
        acceptedAnswer: {
          "@type": "Answer",
          text: item.answer,
        },
      })),
    })} />
    <!-- RN-2I-A SEO END -->
  </head>

  <body class="min-h-screen bg-[#050608] text-white antialiased">
    <main class="relative overflow-hidden">
      <div class="absolute inset-0 -z-10">
        <div class="absolute left-1/2 top-0 h-[520px] w-[900px] -translate-x-1/2 rounded-full bg-blue-500/20 blur-[120px]"></div>
        <div class="absolute right-[-120px] top-[260px] h-[420px] w-[420px] rounded-full bg-cyan-400/10 blur-[100px]"></div>
        <div class="absolute left-[-120px] bottom-[120px] h-[360px] w-[360px] rounded-full bg-white/10 blur-[120px]"></div>
      </div>

      <header class="rn-reveal mx-auto flex max-w-7xl items-center justify-between gap-4 px-4 py-5 sm:px-6">
        <a href="/" class="flex items-center gap-3">
          <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-black p-2 shadow-lg shadow-black/30 ring-1 ring-white/10 sm:h-16 sm:w-16 sm:rounded-3xl">
            <img
              src="/assets/rn-logo.png"
              alt="ReasonableNoise logo"
              class="h-full w-full object-contain"
            />
          </div>
          <div>
            <p class="text-sm font-semibold tracking-wide">ReasonableNoise</p>
            <p class="hidden text-xs text-white/50 sm:block">Premium sticker printing</p>
          </div>
        </a>

        <nav class="hidden items-center gap-8 text-sm text-white/70 md:flex">
          <a class="hover:text-white" href="/usdot-stickers">USDOT Stickers</a>
          <a class="hover:text-white" href="/faq">FAQ</a>
          <a class="hover:text-white" href="/upload-design">Upload Design</a>
        </nav>

        <a
          href="/upload-design"
          class="shrink-0 rounded-full border border-white/15 bg-white px-4 py-3 text-xs font-bold text-black shadow-2xl shadow-white/10 transition hover:bg-white/90 sm:px-5 sm:text-sm"
        >
          Start Order
        </a>
      </header>

      <section class="mx-auto grid max-w-7xl items-center gap-10 px-4 pb-14 pt-8 sm:px-6 md:grid-cols-2 md:gap-14 md:pb-28 md:pt-24">
        <div>
          <div class="rn-reveal rn-delay-1 mb-5 inline-flex max-w-full rounded-full border border-white/10 bg-white/5 px-4 py-2 text-xs leading-5 text-white/70 backdrop-blur sm:text-sm">
            USDOT stickers • custom decals • fleet branding
          </div>

          <h1 class="rn-reveal rn-delay-2 max-w-4xl text-4xl font-semibold tracking-[-0.05em] text-white sm:text-5xl md:text-7xl">
            Premium USDOT Stickers & Custom Decals.
          </h1>

          <p class="rn-reveal rn-delay-3 mt-6 max-w-xl text-base leading-7 text-white/65 sm:text-lg sm:leading-8">
            Built for working vehicles, business fleets, and brands that need sharp, durable stickers without the complicated ordering process.
          </p>

          <div class="rn-reveal rn-delay-4 mt-9 flex flex-col gap-4 sm:flex-row">
            <a
              href="/upload-design"
              class="rounded-full bg-white px-7 py-4 text-center text-sm font-bold text-black shadow-2xl shadow-white/10 transition hover:bg-white/90"
            >
              Order USDOT Stickers
            </a>
            <a
              href="/usdot-stickers"
              class="rounded-full border border-white/15 bg-white/5 px-7 py-4 text-center text-sm font-bold text-white backdrop-blur transition hover:bg-white/10"
            >
              View Products
            </a>
          </div>

          <div class="rn-reveal rn-delay-5 mt-10 grid max-w-lg gap-4 text-sm text-white/60 sm:grid-cols-3">
            <div>
              <p class="text-2xl font-semibold text-white">Vinyl</p>
              <p>Weather-resistant material</p>
            </div>
            <div>
              <p class="text-2xl font-semibold text-white">Fast</p>
              <p>Simple order process</p>
            </div>
            <div>
              <p class="text-2xl font-semibold text-white">Custom</p>
              <p>Upload your own design</p>
            </div>
          </div>
        </div>

        <div class="rn-reveal rn-delay-4 relative">
          <div class="rn-float rounded-[2rem] border border-white/10 bg-white/[0.06] p-4 shadow-2xl shadow-black/40 backdrop-blur-xl sm:rounded-[2.5rem] sm:p-5">
            <div class="rounded-[1.5rem] bg-[#0b0d12] p-4 sm:rounded-[2rem] sm:p-6">
              <div class="mb-5 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                <div>
                  <p class="text-xs uppercase tracking-[0.35em] text-cyan-300">Vehicle decal preview</p>
                  <p class="mt-2 text-xl font-semibold sm:text-2xl">USDOT 1234567</p>
                </div>
                <div class="rn-pulse-soft rounded-full bg-emerald-400/10 px-3 py-1 text-xs font-semibold text-emerald-300">
                  Print Ready
                </div>
              </div>

              <div class="rounded-3xl bg-gradient-to-br from-zinc-900 to-black p-4 sm:p-6">
                <div class="rn-shimmer rounded-2xl border border-white/10 bg-white p-4 text-black shadow-xl sm:p-6">
                  <p class="text-xs font-bold tracking-widest sm:text-sm">REASONABLENOISE LOGISTICS</p>
                  <p class="mt-5 text-4xl font-black tracking-tight sm:text-5xl">USDOT</p>
                  <p class="text-5xl font-black tracking-tighter sm:text-6xl">1234567</p>
                  <p class="mt-5 text-xs font-semibold uppercase tracking-[0.25em] text-black/50">
                    Commercial Vehicle Decal Set
                  </p>
                </div>
              </div>

              <div class="mt-5 grid gap-3 text-xs text-white/60 sm:grid-cols-3">
                <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
                  <p class="font-semibold text-white">2 sides</p>
                  <p>left + right</p>
                </div>
                <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
                  <p class="font-semibold text-white">Custom</p>
                  <p>name + number</p>
                </div>
                <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
                  <p class="font-semibold text-white">Durable</p>
                  <p>outdoor vinyl</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section id="products" class="rn-reveal mx-auto max-w-7xl px-4 py-14 sm:px-6 md:py-20">
        <div class="mb-10 flex flex-col justify-between gap-5 md:flex-row md:items-end">
          <div>
            <p class="text-sm font-semibold uppercase tracking-[0.3em] text-cyan-300">USDOT Stickers</p>
            <h2 class="mt-4 max-w-2xl text-4xl font-semibold tracking-[-0.04em] md:text-5xl">
              Stickers made for vehicles, businesses, and real-world use.
            </h2>
          </div>
          <p class="max-w-md text-white/60">
            Start with USDOT stickers, send your design, or request a custom fleet package.
          </p>
        </div>

        <div class="grid gap-5 md:grid-cols-3">
          {products.map((product) => (
            <article class="rn-hover-lift rounded-[2rem] border border-white/10 bg-white/[0.06] p-7 backdrop-blur transition hover:bg-white/[0.09]">
              <div class="mb-12 h-12 w-12 rounded-2xl bg-white text-black flex items-center justify-center font-black">
                RN
              </div>
              <h3 class="text-2xl font-semibold">{product.title}</h3>
              <p class="mt-4 leading-7 text-white/60">{product.text}</p>
            </article>
          ))}
        </div>
      </section>


      <section id="services" class="rn-reveal mx-auto max-w-7xl px-4 py-14 sm:px-6 md:py-20">
        <div class="grid gap-8 rounded-[2.5rem] border border-white/10 bg-white/[0.06] p-5 backdrop-blur sm:p-8 md:grid-cols-[0.9fr_1.1fr] md:p-12">
          <div>
            <p class="text-sm font-semibold uppercase tracking-[0.3em] text-cyan-300">Custom Decals & Vehicle Lettering</p>
            <h2 class="mt-4 text-4xl font-semibold tracking-[-0.04em] md:text-5xl">
              Sticker printing for business vehicles, fleets, and brands that need a clean professional look.
            </h2>
            <p class="mt-5 leading-7 text-white/60">
              ReasonableNoise creates custom decals, USDOT stickers, truck lettering, business vehicle decals, fleet graphics, and vinyl stickers for commercial vehicles and brands. The order process is built for speed: choose the sticker type, upload artwork or order details, select pickup or shipping, and pay securely through Stripe.
            </p>
          </div>

          <div class="grid gap-4 sm:grid-cols-2">
            <div class="rounded-3xl border border-white/10 bg-black/20 p-5">
              <p class="font-bold text-white">USDOT stickers</p>
              <p class="mt-2 text-sm leading-6 text-white/55">
                Clean USDOT number decals for trucks, trailers, vans, and commercial vehicle doors.
              </p>
            </div>

            <div class="rounded-3xl border border-white/10 bg-black/20 p-5">
              <p class="font-bold text-white">Custom business decals</p>
              <p class="mt-2 text-sm leading-6 text-white/55">
                Upload a logo, artwork file, or design reference for custom vinyl decals.
              </p>
            </div>

            <div class="rounded-3xl border border-white/10 bg-black/20 p-5">
              <p class="font-bold text-white">Fleet lettering</p>
              <p class="mt-2 text-sm leading-6 text-white/55">
                Keep vehicle branding consistent across multiple trucks, vans, trailers, or service vehicles.
              </p>
            </div>

            <div class="rounded-3xl border border-white/10 bg-black/20 p-5">
              <p class="font-bold text-white">Secure order flow</p>
              <p class="mt-2 text-sm leading-6 text-white/55">
                Upload artwork, choose local pickup or shipping, and pay the order deposit online.
              </p>
            </div>
          </div>
        </div>
      </section>

      <section id="process" class="rn-reveal rn-delay-1 mx-auto max-w-7xl px-4 py-14 sm:px-6 md:py-20">
        <div class="rounded-[2rem] border border-white/10 bg-white/[0.06] p-5 sm:p-8 md:rounded-[2.5rem] md:p-12">
          <p class="text-sm font-semibold uppercase tracking-[0.3em] text-cyan-300">Simple Process</p>
          <h2 class="mt-4 max-w-3xl text-4xl font-semibold tracking-[-0.04em] md:text-5xl">
            From idea to print-ready sticker without the back and forth.
          </h2>

          <div class="mt-10 grid gap-4 md:grid-cols-4">
            {steps.map((step, index) => (
              <div class="rounded-3xl border border-white/10 bg-black/20 p-6">
                <p class="text-sm text-white/40">0{index + 1}</p>
                <p class="mt-8 text-lg font-semibold">{step}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section id="quote" class="rn-reveal rn-delay-2 mx-auto max-w-7xl px-4 py-14 sm:px-6 md:py-20">
        <div class="grid gap-8 rounded-[2rem] border border-white/10 bg-white p-5 text-black sm:p-8 md:grid-cols-2 md:rounded-[2.5rem] md:p-12">
          <div>
            <p class="text-sm font-bold uppercase tracking-[0.3em] text-black/50">Start your order</p>
            <h2 class="mt-4 text-4xl font-semibold tracking-[-0.04em] md:text-5xl">
              Upload your design or request USDOT stickers.
            </h2>
            <p class="mt-5 max-w-lg leading-7 text-black/60">
              Start a secure order, upload artwork, choose pickup or shipping, and pay the order deposit through Stripe.
            </p>
          </div>

          <form class="rounded-[2rem] border border-black/10 bg-black/[0.03] p-6">
            <div class="grid gap-4">
              <input class="rounded-2xl border border-black/10 bg-white px-5 py-4 outline-none" placeholder="Your name" />
              <input class="rounded-2xl border border-black/10 bg-white px-5 py-4 outline-none" placeholder="Email address" />
              <input class="rounded-2xl border border-black/10 bg-white px-5 py-4 outline-none" placeholder="USDOT number or sticker type" />
              <textarea class="min-h-32 rounded-2xl border border-black/10 bg-white px-5 py-4 outline-none" placeholder="Tell us what you need printed"></textarea>
              <a href="/upload-design" class="rounded-full bg-black px-6 py-4 text-center text-sm font-bold text-white">
                Start Secure Order
              </a>
            </div>
          </form>
        </div>
      </section>



      <section id="dtf-coming-soon" class="rn-reveal mx-auto max-w-7xl px-4 py-14 sm:px-6 md:py-20">
        <div class="grid gap-8 rounded-[2.5rem] border border-white/10 bg-white/[0.06] p-5 backdrop-blur sm:p-8 md:grid-cols-[0.9fr_1.1fr] md:p-12">
          <div>
            <p class="text-sm font-semibold uppercase tracking-[0.3em] text-cyan-300">Coming Soon</p>
            <h2 class="mt-4 text-4xl font-semibold tracking-[-0.04em] md:text-5xl">
              DTF T-Shirt Printing for brands, teams, and small businesses.
            </h2>
            <p class="mt-5 leading-7 text-white/60">
              ReasonableNoise is preparing custom DTF shirt printing for logo shirts, event shirts, work shirts, and small business apparel. This service is not accepting paid checkout yet, but early quote requests can be reviewed while production is being prepared.
            </p>
          </div>

          <div class="rounded-[2rem] border border-cyan-300/20 bg-cyan-300/10 p-6">
            <p class="text-sm font-semibold uppercase tracking-[0.25em] text-cyan-200">Estimated launch pricing</p>
            <div class="mt-5 grid gap-4">
              <div class="flex items-center justify-between gap-4 border-b border-white/10 pb-3">
                <span class="text-white/70">Single custom shirt</span>
                <span class="font-bold text-white">From $24</span>
              </div>
              <div class="flex items-center justify-between gap-4 border-b border-white/10 pb-3">
                <span class="text-white/70">Small batch 6+</span>
                <span class="font-bold text-white">From $20/shirt</span>
              </div>
              <div class="flex items-center justify-between gap-4 border-b border-white/10 pb-3">
                <span class="text-white/70">Bulk 12+</span>
                <span class="font-bold text-white">From $18/shirt</span>
              </div>
              <div class="flex items-center justify-between gap-4">
                <span class="text-white/70">Front + back print</span>
                <span class="font-bold text-white">Quote required</span>
              </div>
            </div>
            <p class="mt-5 text-sm leading-6 text-white/55">
              Placeholder pricing only. Final DTF availability and pricing will be confirmed when production is ready.
            </p>
          </div>
        </div>
      </section>

      <section id="home-faq" class="rn-reveal rn-delay-1 mx-auto max-w-7xl px-4 py-14 sm:px-6 md:py-20">
        <div class="mb-10">
          <p class="text-sm font-semibold uppercase tracking-[0.3em] text-cyan-300">FAQ</p>
          <h2 class="mt-4 max-w-3xl text-4xl font-semibold tracking-[-0.04em] md:text-5xl">
            Common sticker order questions.
          </h2>
        </div>

        <div class="grid gap-4 md:grid-cols-3">
          {homeSeoFaqs.map((item) => (
            <article class="rn-hover-lift rounded-[2rem] border border-white/10 bg-white/[0.06] p-6 backdrop-blur">
              <h3 class="text-xl font-semibold text-white">{item.question}</h3>
              <p class="mt-4 leading-7 text-white/60">{item.answer}</p>
            </article>
          ))}
        </div>
      </section>

      <footer class="mx-auto flex max-w-7xl flex-col gap-4 px-4 py-10 text-sm text-white/45 sm:px-6 md:flex-row md:items-center md:justify-between">
        <p>© 2026 ReasonableNoise. Premium sticker printing.</p>
        <div class="flex flex-wrap gap-5">
          <a href="/privacy" class="hover:text-white">Privacy</a>
          <a href="/terms" class="hover:text-white">Terms</a>
          <a href="/upload-design" class="hover:text-white">Contact</a>
        </div>
      </footer>
    </main>
      <WhatsAppChat />
  </body>
</html>








