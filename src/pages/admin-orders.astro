---
import "../styles/global.css";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Admin Orders | ReasonableNoise</title>
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/png" href="/assets/rn-logo.png" />
  </head>

  <body class="min-h-screen bg-[#050608] text-white antialiased">
    <main class="mx-auto max-w-7xl px-4 py-8 sm:px-6">
      <header class="flex flex-col gap-5 sm:flex-row sm:items-center sm:justify-between">
        <a href="/" class="flex items-center gap-3">
          <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-black p-2 shadow-lg shadow-black/30 ring-1 ring-white/10">
            <img src="/assets/rn-logo.png" alt="ReasonableNoise logo" class="h-full w-full object-contain" />
          </div>
          <div>
            <p class="font-semibold">ReasonableNoise Admin</p>
            <p class="text-xs text-white/50">Orders Center</p>
          </div>
        </a>

        <div class="flex flex-col gap-2 sm:flex-row">
          <button id="refresh-button" class="rounded-full border border-white/15 px-5 py-3 text-sm font-bold text-white">
            Refresh Orders
          </button>
          <button id="clear-token-button" class="rounded-full bg-white px-5 py-3 text-sm font-bold text-black">
            Clear Admin Session
          </button>
        </div>
      </header>

      <section class="mt-10 grid gap-6 lg:grid-cols-[0.75fr_1.25fr]">
        <aside class="rounded-[2rem] border border-white/10 bg-white/[0.06] p-6">
          <p class="text-sm font-semibold uppercase tracking-[0.25em] text-cyan-300">Cloudflare Access + Token</p>
          <h1 class="mt-4 text-4xl font-semibold tracking-[-0.04em]">Manage orders without terminal.</h1>
          <p class="mt-4 text-sm leading-6 text-white/60">
            Cloudflare Access protects this admin area. Once your email login is approved, orders load automatically without pasting an admin token.
          </p>

          <div class="mt-6 rounded-3xl border border-emerald-400/20 bg-emerald-400/10 p-5 text-sm text-emerald-100">
            <p class="font-bold text-white">Access verified</p>
            <p class="mt-2 leading-6">
              You are inside the Cloudflare-protected admin area. Use Refresh Orders to reload recent order records.
            </p>
          </div>

          <p id="admin-message" class="mt-4 hidden rounded-2xl border px-4 py-3 text-sm"></p>

          <div class="mt-6 rounded-3xl border border-white/10 bg-black/20 p-5 text-sm text-white/60">
            <p class="font-bold text-white">Security note</p>
            <p class="mt-2 leading-6">
              Protected by Cloudflare Access email login. Use Clear Admin Session or close the browser when finished on a shared computer. ADMIN_ORDER_TOKEN remains only as an emergency backend fallback.
            </p>
          </div>
        </aside>

        <section class="rounded-[2rem] bg-white p-5 text-black shadow-2xl shadow-black/30 sm:p-6">
          <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
            <div>
              <p class="text-sm font-bold uppercase tracking-[0.25em] text-black/40">Orders</p>
              <h2 class="mt-2 text-3xl font-bold tracking-[-0.04em]">Recent order records</h2>
            </div>
            <p id="orders-count" class="text-sm text-black/50">Not loaded</p>
          </div>

          <div class="mt-6 grid gap-3 rounded-3xl border border-black/10 bg-black/[0.03] p-4 md:grid-cols-[1fr_180px_auto_auto] md:items-end">
            <div>
              <label class="block text-xs font-bold uppercase tracking-[0.18em] text-black/40" for="admin-order-search">Search</label>
              <input
                id="admin-order-search"
                type="search"
                placeholder="Search order, customer, email, tracking..."
                class="mt-2 w-full rounded-2xl border border-black/10 bg-white px-4 py-3 text-sm outline-none"
              />
            </div>

            <div>
              <label class="block text-xs font-bold uppercase tracking-[0.18em] text-black/40" for="admin-status-filter">Status</label>
              <select id="admin-status-filter" class="mt-2 w-full rounded-2xl border border-black/10 bg-white px-4 py-3 text-sm outline-none">
                <option value="">All statuses</option>
                <option value="order_received">Order received</option>
                <option value="artwork_review_started">Artwork review started</option>
                <option value="ready_for_pickup">Ready for pickup</option>
                <option value="shipped">Shipped</option>
                <option value="completed">Completed</option>
              </select>
            </div>

            <label class="flex items-center gap-2 rounded-2xl border border-black/10 bg-white px-4 py-3 text-sm font-semibold text-black/70">
              <input id="admin-show-test-orders" type="checkbox" class="h-4 w-4" />
              Show test orders
            </label>

            <label class="flex items-center gap-2 rounded-2xl border border-black/10 bg-white px-4 py-3 text-sm font-semibold text-black/70">
              <input id="admin-show-completed-orders" type="checkbox" class="h-4 w-4" />
              Show completed
            </label>
          </div>

          <div id="orders-list" class="mt-6 grid gap-4">
            <div class="rounded-3xl border border-black/10 bg-black/[0.03] p-5 text-sm text-black/55">
              Enter your admin token to load orders.
            </div>
          </div>

          <button id="load-more-button" class="mt-5 hidden w-full rounded-full border border-black/10 px-5 py-3 text-sm font-bold text-black">
            Load More
          </button>
        </section>
      </section>
    </main>

    <script>
      const params = new URLSearchParams(window.location.search);
      const tokenFromUrl = params.get("token") || "";

      if (tokenFromUrl) {
        sessionStorage.setItem("rnAdminOrderToken", tokenFromUrl);
        params.delete("token");
        const cleanUrl = `${window.location.pathname}${params.toString() ? `?${params.toString()}` : ""}`;
        window.history.replaceState({}, "", cleanUrl);
      }

      const tokenForm = document.getElementById("token-form");
      const tokenInput = document.getElementById("admin-token");
      const message = document.getElementById("admin-message");
      const ordersList = document.getElementById("orders-list");
      const ordersCount = document.getElementById("orders-count");
      const refreshButton = document.getElementById("refresh-button");
      const clearTokenButton = document.getElementById("clear-token-button");
      const loadMoreButton = document.getElementById("load-more-button");
      const searchInput = document.getElementById("admin-order-search");
      const statusFilter = document.getElementById("admin-status-filter");
      const showTestOrdersInput = document.getElementById("admin-show-test-orders");
      const showCompletedOrdersInput = document.getElementById("admin-show-completed-orders");

      let nextCursor = "";
      let loadedOrders = [];

      function escapeHtml(value) {
        return String(value || "")
          .replaceAll("&", "&amp;")
          .replaceAll("<", "&lt;")
          .replaceAll(">", "&gt;")
          .replaceAll('"', "&quot;")
          .replaceAll("'", "&#039;");
      }

      function showMessage(text, isError = false) {
        message.textContent = text;
        message.classList.remove("hidden");
        message.classList.toggle("border-red-400/30", isError);
        message.classList.toggle("bg-red-400/10", isError);
        message.classList.toggle("text-red-100", isError);
        message.classList.toggle("border-emerald-400/30", !isError);
        message.classList.toggle("bg-emerald-400/10", !isError);
        message.classList.toggle("text-emerald-100", !isError);
      }

      function getToken() {
        return sessionStorage.getItem("rnAdminOrderToken") || "";
      }

      function isTestOrder(order) {
        return String(order.order_reference || "").startsWith("RN-TEST-") || String(order.source || "").includes("test");
      }

      function getVisibleOrders() {
        const query = String(searchInput?.value || "").trim().toLowerCase();
        const status = String(statusFilter?.value || "").trim();
        const showTests = Boolean(showTestOrdersInput?.checked);
        const showCompleted = Boolean(showCompletedOrdersInput?.checked);

        return loadedOrders.filter((order) => {
          if (!showTests && isTestOrder(order)) return false;
          if (!showCompleted && !status && order.status === "completed") return false;
          if (status && order.status !== status) return false;

          if (!query) return true;

          const haystack = [
            order.order_reference,
            order.customer_name,
            order.customer_email,
            order.business_name,
            order.order_type,
            order.fulfillment_method,
            order.tracking_number,
            order.carrier,
            order.status_label,
          ]
            .join(" ")
            .toLowerCase();

          return haystack.includes(query);
        });
      }

      function refreshVisibleOrders() {
        renderOrders(getVisibleOrders(), false);
        const total = loadedOrders.length;
        const visible = getVisibleOrders().length;
        ordersCount.textContent = `${visible} shown / ${total} loaded${nextCursor ? " — more available" : ""}`;
      }

      function statusBadgeClass(status) {
        if (status === "shipped") return "bg-blue-50 text-blue-700 border-blue-100";
        if (status === "ready_for_pickup") return "bg-emerald-50 text-emerald-700 border-emerald-100";
        if (status === "completed") return "bg-black text-white border-black";
        if (status === "artwork_review_started") return "bg-amber-50 text-amber-700 border-amber-100";
        return "bg-black/[0.04] text-black/60 border-black/10";
      }

      function renderOrders(orders, append = false) {
        if (!append) {
          ordersList.innerHTML = "";
        }

        if (!orders.length && !append) {
          ordersList.innerHTML = `
            <div class="rounded-3xl border border-black/10 bg-black/[0.03] p-5 text-sm text-black/55">
              No matching order records found. Adjust filters, enable “Show test orders,” or enable “Show completed.”
            </div>
          `;
          return;
        }

        for (const order of orders) {
          const updateUrl = `/admin-order-update?order_ref=${encodeURIComponent(order.order_reference || "")}`;

          const card = document.createElement("article");
          card.className = "rounded-3xl border border-black/10 bg-black/[0.03] p-5";

          card.innerHTML = `
            <div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
              <div>
                <div class="flex flex-wrap items-center gap-2">
                  <h3 class="text-lg font-bold">${escapeHtml(order.order_reference || "Unknown order")}</h3>
                  <span class="rounded-full border px-3 py-1 text-xs font-bold ${statusBadgeClass(order.status)}">
                    ${escapeHtml(order.status_label || order.status || "Unknown")}
                  </span>
                </div>

                <div class="mt-3 grid gap-1 text-sm text-black/60">
                  <p><strong class="text-black">Customer:</strong> ${escapeHtml(order.customer_name || "Not provided")} — ${escapeHtml(order.customer_email || "No email")}</p>
                  <p><strong class="text-black">Order:</strong> ${escapeHtml(order.order_type || "Sticker order")} / ${escapeHtml(order.fulfillment_method || "Not provided")}</p>
                  <p><strong class="text-black">Paid:</strong> ${escapeHtml(order.amount_total || "Not provided")}</p>
                  ${order.tracking_number ? `<p><strong class="text-black">Tracking:</strong> ${escapeHtml(order.carrier)} ${escapeHtml(order.tracking_number)}</p>` : ""}
                  <p><strong class="text-black">Updated:</strong> ${escapeHtml(order.updated_at || "Not provided")}</p>
                </div>
              </div>

              <a href="${updateUrl}" class="rounded-full bg-black px-5 py-3 text-center text-sm font-bold text-white">
                Open Order
              </a>
            </div>
          `;

          ordersList.appendChild(card);
        }
      }

      async function loadOrders(append = false) {
        const token = getToken();

        if (!append) {
          nextCursor = "";
          ordersList.innerHTML = `
            <div class="rounded-3xl border border-black/10 bg-black/[0.03] p-5 text-sm text-black/55">
              Loading orders...
            </div>
          `;
        }

        try {
          const response = await fetch(`/api/admin-orders?limit=50${nextCursor ? `&cursor=${encodeURIComponent(nextCursor)}` : ""}`, {
            headers: token
              ? {
                  "x-admin-order-token": token,
                }
              : {},
          });

          const data = await response.json();

          if (!response.ok || !data.success) {
            throw new Error(data.error || "Unable to load orders.");
          }

          loadedOrders = append
            ? loadedOrders.concat(data.orders || [])
            : data.orders || [];

          nextCursor = data.cursor || "";
          loadMoreButton.classList.toggle("hidden", !nextCursor);
          refreshVisibleOrders();
          showMessage("Orders loaded.", false);
        } catch (error) {
          ordersList.innerHTML = `
            <div class="rounded-3xl border border-red-100 bg-red-50 p-5 text-sm text-red-700">
              ${escapeHtml(error.message || "Unable to load orders.")}
            </div>
          `;
          showMessage(error.message || "Unable to load orders.", true);
        }
      }

      tokenForm?.addEventListener("submit", (event) => {
        event.preventDefault();

        const token = tokenInput?.value?.trim() || "";

        if (!token) {
          showMessage("Paste your admin token first.", true);
          return;
        }

        sessionStorage.setItem("rnAdminOrderToken", token);
        tokenInput.value = "";
        loadOrders(false);
      });

      refreshButton.addEventListener("click", () => loadOrders(false));
      loadMoreButton.addEventListener("click", () => loadOrders(true));
      searchInput?.addEventListener("input", refreshVisibleOrders);
      statusFilter?.addEventListener("change", refreshVisibleOrders);
      showTestOrdersInput?.addEventListener("change", refreshVisibleOrders);
      showCompletedOrdersInput?.addEventListener("change", refreshVisibleOrders);

      clearTokenButton.addEventListener("click", () => {
        sessionStorage.removeItem("rnAdminOrderToken");
        ordersList.innerHTML = `
          <div class="rounded-3xl border border-black/10 bg-black/[0.03] p-5 text-sm text-black/55">
            Admin session cleared. Refresh the page to re-check Cloudflare Access.
          </div>
        `;
        loadedOrders = [];
        ordersCount.textContent = "Not loaded";
        showMessage("Admin session cleared.", false);
      });

      loadOrders(false);
    </script>
  </body>
</html>
