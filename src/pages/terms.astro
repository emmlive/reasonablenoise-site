---
import "../styles/global.css";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Terms of Service | ReasonableNoise</title>
    <meta name="description" content="Read the ReasonableNoise terms of service for sticker orders, artwork uploads, deposits, pickup, shipping, and production details." />
    <link rel="icon" type="image/png" href="/assets/rn-logo.png" />
    <link rel="shortcut icon" type="image/png" href="/assets/rn-logo.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
  
    <!-- RN-2I-A SEO START -->
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://reasonablenoise.com/terms/" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="ReasonableNoise" />
    <meta property="og:title" content="Terms of Service | ReasonableNoise" />
    <meta property="og:description" content="Read the ReasonableNoise terms of service for sticker orders, artwork uploads, deposits, pickup, shipping, and production details." />
    <meta property="og:url" content="https://reasonablenoise.com/terms/" />
    <meta property="og:image" content="https://reasonablenoise.com/assets/rn-logo.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Terms of Service | ReasonableNoise" />
    <meta name="twitter:description" content="Read the ReasonableNoise terms of service for sticker orders, artwork uploads, deposits, pickup, shipping, and production details." />
    <meta name="twitter:image" content="https://reasonablenoise.com/assets/rn-logo.png" />
    <!-- RN-2I-A SEO END -->
  </head>

  <body class="min-h-screen bg-[#050608] text-white antialiased">
    <main class="mx-auto max-w-4xl px-6 py-16">
      <a href="/" class="inline-flex items-center gap-3 text-sm text-white/60 hover:text-white">
        <span class="flex h-9 w-9 items-center justify-center rounded-2xl bg-white text-xs font-black text-black">RN</span>
        Back to ReasonableNoise
      </a>

      <section class="py-16">
        <p class="text-sm font-semibold uppercase tracking-[0.3em] text-cyan-300">Terms of Service</p>
        <h1 class="mt-5 text-5xl font-semibold tracking-[-0.05em]">Terms of Service</h1>
        <p class="mt-5 text-white/50">Last updated: June 2026</p>

        <div class="mt-10 space-y-8 leading-8 text-white/65">
          <p>
            These terms apply to use of the ReasonableNoise website and custom sticker printing services.
          </p>

          <section>
            <h2 class="text-2xl font-semibold text-white">Custom orders</h2>
            <p class="mt-3">
              Custom sticker and decal orders are prepared based on the details, files, and instructions provided by the customer. Customers are responsible for reviewing order details before approval or payment.
            </p>
          </section>

          <section>
            <h2 class="text-2xl font-semibold text-white">Artwork and file uploads</h2>
            <p class="mt-3">
              Customers must have the right to use any logo, design, image, trademark, or artwork submitted for printing. ReasonableNoise may decline orders that appear unlawful, infringing, or inappropriate.
            </p>
          </section>

          <section>
            <h2 class="text-2xl font-semibold text-white">USDOT sticker information</h2>
            <p class="mt-3">
              Customers are responsible for providing accurate USDOT numbers, legal names, business names, and vehicle marking details. ReasonableNoise prints the information provided by the customer.
            </p>
          </section>

          <section>
            <h2 class="text-2xl font-semibold text-white">Payments</h2>
            <p class="mt-3">
              Payments may be processed through Stripe, PayPal, or another supported payment provider. Orders may not be printed or fulfilled until payment or approval requirements are completed.
            </p>
          </section>

          <section>
            <h2 class="text-2xl font-semibold text-white">Contact</h2>
            <p class="mt-3">
              For questions about these terms, contact ReasonableNoise through the order or contact form on this website.
            </p>
          </section>
        </div>
      </section>
    </main>
  </body>
</html>




