---
import "../styles/global.css";
import SiteAnalytics from "../components/SiteAnalytics.astro";
import WhatsAppChat from "../components/WhatsAppChat.astro";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>DTF T-Shirt Printing Coming Soon | ReasonableNoise</title>
    <meta name="description" content="DTF T-shirt printing is coming soon at ReasonableNoise. Request a quote for custom shirts, logo shirts, event shirts, work shirts, and small business apparel." />
    <link rel="icon" type="image/png" href="/assets/rn-logo.png" />
    <link rel="shortcut icon" type="image/png" href="/assets/rn-logo.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://reasonablenoise.com/dtf-shirts/" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="ReasonableNoise" />
    <meta property="og:title" content="DTF T-Shirt Printing Coming Soon | ReasonableNoise" />
    <meta property="og:description" content="Request a quote for upcoming DTF T-shirt printing for brands, teams, events, and small businesses." />
    <meta property="og:url" content="https://reasonablenoise.com/dtf-shirts/" />
    <meta property="og:image" content="https://reasonablenoise.com/assets/rn-logo.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="DTF T-Shirt Printing Coming Soon | ReasonableNoise" />
    <meta name="twitter:description" content="Request a quote for upcoming DTF T-shirt printing for brands, teams, events, and small businesses." />
    <meta name="twitter:image" content="https://reasonablenoise.com/assets/rn-logo.png" />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Service",
      name: "DTF T-shirt printing coming soon",
      provider: {
        "@type": "Organization",
        name: "ReasonableNoise",
        url: "https://reasonablenoise.com",
      },
      serviceType: "DTF T-shirt printing, logo shirts, event shirts, work shirts, and small business apparel",
      areaServed: "United States",
      url: "https://reasonablenoise.com/dtf-shirts/",
    })} />
  </head>

  <body class="min-h-screen bg-[#050608] text-white antialiased">
    <main class="relative overflow-hidden">
      <div class="absolute inset-0 -z-10">
        <div class="absolute left-1/2 top-0 h-[520px] w-[900px] -translate-x-1/2 rounded-full bg-cyan-500/15 blur-[120px]"></div>
      </div>

      <header class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-4 py-5 sm:px-6">
        <a href="/" class="flex items-center gap-3">
          <div class="flex h-16 w-16 items-center justify-center rounded-3xl bg-black p-2 shadow-lg shadow-black/30 ring-1 ring-white/10">
            <img src="/assets/rn-logo.png" alt="ReasonableNoise logo" class="h-full w-full object-contain" />
          </div>
          <div>
            <p class="text-sm font-semibold tracking-wide">ReasonableNoise</p>
            <p class="text-xs text-white/50">Premium sticker printing</p>
          </div>
        </a>

        <nav class="hidden items-center gap-8 text-sm text-white/70 md:flex">
          <a class="hover:text-white" href="/">Home</a>
          <a class="hover:text-white" href="/usdot-stickers">USDOT Stickers</a>
          <a class="hover:text-white" href="/upload-design">Upload Design</a>
          <a class="hover:text-white" href="/contact">Contact</a>
        </nav>

        <a href="/contact?topic=dtf" class="rounded-full bg-white px-5 py-2.5 text-sm font-semibold text-black">
          Request Quote
        </a>
      </header>

      <section class="mx-auto grid max-w-7xl gap-8 px-4 py-16 sm:px-6 md:grid-cols-[0.95fr_1.05fr] md:py-24">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.3em] text-cyan-300">Coming Soon</p>
          <h1 class="mt-5 text-5xl font-semibold tracking-[-0.05em] md:text-7xl">
            DTF T-shirt printing quote requests.
          </h1>
          <p class="mt-6 max-w-2xl text-lg leading-8 text-white/60">
            ReasonableNoise is preparing DTF T-shirt printing for logo shirts, work shirts, event shirts, team shirts, and small business apparel. This service is not paid-checkout enabled yet, but quote requests are open.
          </p>

          <div class="mt-9 flex flex-col gap-4 sm:flex-row">
            <a href="/contact?topic=dtf" class="rounded-full bg-white px-6 py-3 text-center text-sm font-bold text-black">
              Request DTF Quote
            </a>
            <a href="/upload-design" class="rounded-full border border-white/15 px-6 py-3 text-center text-sm font-bold text-white">
              Order Stickers Instead
            </a>
          </div>
        </div>

        <div class="rounded-[2.5rem] border border-cyan-300/20 bg-cyan-300/10 p-6 sm:p-8">
          <p class="text-sm font-semibold uppercase tracking-[0.25em] text-cyan-200">Estimated launch pricing</p>

          <div class="mt-7 grid gap-4">
            <div class="flex items-center justify-between gap-4 rounded-3xl border border-white/10 bg-black/20 p-5">
              <span class="text-white/70">Single custom shirt</span>
              <span class="text-2xl font-bold text-white">From $24</span>
            </div>
            <div class="flex items-center justify-between gap-4 rounded-3xl border border-white/10 bg-black/20 p-5">
              <span class="text-white/70">Small batch 6+</span>
              <span class="text-2xl font-bold text-white">From $20/shirt</span>
            </div>
            <div class="flex items-center justify-between gap-4 rounded-3xl border border-white/10 bg-black/20 p-5">
              <span class="text-white/70">Bulk 12+</span>
              <span class="text-2xl font-bold text-white">From $18/shirt</span>
            </div>
            <div class="flex items-center justify-between gap-4 rounded-3xl border border-white/10 bg-black/20 p-5">
              <span class="text-white/70">Front + back print</span>
              <span class="text-2xl font-bold text-white">Quote</span>
            </div>
          </div>

          <p class="mt-6 text-sm leading-6 text-white/60">
            Placeholder pricing only. Final pricing depends on shirt type, quantity, artwork, print size, front/back placement, and production readiness.
          </p>
        </div>
      </section>

      <section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 md:py-16">
        <div class="rounded-[2.5rem] border border-white/10 bg-white/[0.06] p-5 backdrop-blur sm:p-8 md:p-12">
          <p class="text-sm font-semibold uppercase tracking-[0.3em] text-cyan-300">What to include</p>
          <h2 class="mt-4 max-w-3xl text-4xl font-semibold tracking-[-0.04em] md:text-5xl">
            Send the details needed for a faster quote.
          </h2>

          <div class="mt-8 grid gap-4 md:grid-cols-3">
            <article class="rounded-3xl border border-white/10 bg-black/20 p-5">
              <h3 class="font-bold text-white">Quantity and shirt color</h3>
              <p class="mt-3 text-sm leading-6 text-white/55">Tell us how many shirts you need and the shirt color preference.</p>
            </article>
            <article class="rounded-3xl border border-white/10 bg-black/20 p-5">
              <h3 class="font-bold text-white">Artwork and print size</h3>
              <p class="mt-3 text-sm leading-6 text-white/55">Mention whether your artwork is ready and how large the print should be.</p>
            </article>
            <article class="rounded-3xl border border-white/10 bg-black/20 p-5">
              <h3 class="font-bold text-white">Front, back, or both</h3>
              <p class="mt-3 text-sm leading-6 text-white/55">Let us know if the design goes on the front, back, sleeve, or multiple locations.</p>
            </article>
          </div>
        </div>
      </section>

      <footer class="mx-auto flex max-w-7xl flex-col gap-4 px-4 py-10 text-sm text-white/45 sm:px-6 md:flex-row md:items-center md:justify-between">
        <p>© 2026 ReasonableNoise. Premium sticker printing.</p>
        <div class="flex flex-wrap gap-5">
          <a href="/" class="hover:text-white">Home</a>
          <a href="/upload-design" class="hover:text-white">Upload Design</a>
          <a href="/contact" class="hover:text-white">Contact</a>
          <a href="/privacy" class="hover:text-white">Privacy</a>
          <a href="/terms" class="hover:text-white">Terms</a>
        </div>
      </footer>
    </main>

    <WhatsAppChat />
      <SiteAnalytics />
  </body>
</html>
